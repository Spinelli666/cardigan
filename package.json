{
  "name": "cardigan",
  "version": "1.3.7",
  "description": "Build tools for the Cardigan RPG system for Foundry VTT",
  "scripts": {
    "build": "sass src/scss/cardigan.scss css/cardigan.css --style=expanded --no-source-map",
    "watch": "sass src/scss/cardigan.scss css/cardigan.css --style=expanded --source-map --watch",
    "build:packs": "node scripts/build-packs.mjs",
    "build:all": "npm run build && npm run build:packs"
  },
  "browserslist": [
    "last 3 versions"
  ],
  "author": "Spinelli666",
  "license": "MIT",
  "private": true,
  "devDependencies": {
    "@foundryvtt/foundryvtt-cli": "^1.1.0",
    "sass": "^1.53.0"
  }
}
