          {{#if @root.editable}}
            <a class='item-control item-create' title='{{localize "CARDIGAN.AddCarpentryRecipe"}}' data-action='createDoc' data-document-class='Item' data-type='carpentry-recipe' data-name='New Carpentry Recipe'>
              <i class='fas fa-plus'></i>
              {{localize "CARDIGAN.AddCarpentryRecipe"}}
            </a>
          {{/if}}
        </div>
      </li>
      {{#each carpentryRecipes as |recipe id|}}
        <li
          class='item collapsible collapsed'
          data-item-id='{{recipe._id}}'
          data-uuid='{{recipe.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Item Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{recipe.img}}' title='{{recipe.name}}' width='24' height='24'/>
              </div>
              <div 
                class="recipe-name-hover"
                data-tooltip-direction="UP"
                data-tooltip-class="cardigan-tooltip"
                data-item-id="{{recipe._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{recipe.name}}
              </div>
            </div>
            <div class='item-controls'>
              {{#if @root.editable}}
                <a class='item-control item-craft' title='{{localize "CARDIGAN.CraftItem"}}' data-action='craftFromRecipe' data-recipe-id='{{recipe._id}}' data-recipe-type='carpentry'>
                  <i class='fas fa-hammer' style='color: #8bc34a;'></i>
                </a>
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
                <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                  <i class='fas fa-trash'></i>
                </a>
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-tools" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #8bc34a;"></i>
            <p>No carpentry recipes learned yet.</p>
            <p style="font-size: 12px;">Click "Add Carpentry Recipe" to start collecting recipes for carpentry.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

  {{! Equipment backpack info - keeping for reference }}
  <div style="margin-top: 40px; padding: 20px; background: rgba(0, 0, 0, 0.1); border-radius: 8px; text-align: center; color: #a59b85;">
    <p style="font-size: 14px; margin: 0;">
      <i class="fas fa-info-circle" style="margin-right: 8px;"></i>
      Use the profession tables above to organize and manage your crafting recipes. Each profession has its own dedicated space for recipes and materials.
    </p>
  </div>

</section>