{{! Skills Tab with Profession Recipe Tables }}
<section class='tab skills {{tab.cssClass}}' data-group='primary' data-tab='skills'>
  
  {{! SKILL CLASS TABLE TOGGLES - All checkboxes at the top }}
  <div class="skill-toggles-container" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px; padding: 20px; background: rgba(0, 0, 0, 0.2); border-radius: 8px;">
    {{! Andarilho Skills Toggle }}
    <div class="skill-table-toggle andarilho-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsAndarilhoTable" {{checked system.details.showSkillsAndarilhoTable}} data-dtype="Boolean" data-andarilho-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-hiking" style="color: #8bc34a;"></i>
        {{localize "CARDIGAN.ShowSkillsAndarilhoTable"}}
      </label>
    </div>
    
    {{! Guerreiro Skills Toggle }}
    <div class="skill-table-toggle guerreiro-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsGuerreiroTable" {{checked system.details.showSkillsGuerreiroTable}} data-dtype="Boolean" data-guerreiro-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-sword" style="color: #f44336;"></i>
        {{localize "CARDIGAN.ShowSkillsGuerreiroTable"}}
      </label>
    </div>
    
    {{! Ladino Skills Toggle }}
    <div class="skill-table-toggle ladino-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsLadinoTable" {{checked system.details.showSkillsLadinoTable}} data-dtype="Boolean" data-ladino-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-mask" style="color: #9c27b0;"></i>
        {{localize "CARDIGAN.ShowSkillsLadinoTable"}}
      </label>
    </div>
    
    {{! Feiticeiro Skills Toggle }}
    <div class="skill-table-toggle feiticeiro-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsFeiticeiroTable" {{checked system.details.showSkillsFeiticeiroTable}} data-dtype="Boolean" data-feiticeiro-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-magic" style="color: #2196f3;"></i>
        {{localize "CARDIGAN.ShowSkillsFeiticeiroTable"}}
      </label>
    </div>
    
    {{! Raciais Skills Toggle }}
    <div class="skill-table-toggle raciais-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsRaciaisTable" {{checked system.details.showSkillsRaciaisTable}} data-dtype="Boolean" data-raciais-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-users" style="color: #ff9800;"></i>
        {{localize "CARDIGAN.ShowSkillsRaciaisTable"}}
      </label>
    </div>
    
    {{! Únicas Skills Toggle }}
    <div class="skill-table-toggle unicas-skills-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showSkillsUnicasTable" {{checked system.details.showSkillsUnicasTable}} data-dtype="Boolean" data-unicas-skills-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-star" style="color: #ffc107;"></i>
        {{localize "CARDIGAN.ShowSkillsUnicasTable"}}
      </label>
    </div>
  </div>

  {{! PROFESSION TABLE TOGGLES - All checkboxes at the top }}
  <div class="profession-toggles-container" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px; padding: 20px; background: rgba(0, 0, 0, 0.2); border-radius: 8px;">
    {{! Culinary Toggle }}
    <div class="profession-table-toggle culinary-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showCulinaryTable" {{checked system.details.showCulinaryTable}} data-dtype="Boolean" data-culinary-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-utensils" style="color: #ff6b35;"></i>
        {{localize "CARDIGAN.ShowCulinaryTable"}}
      </label>
    </div>
    
    {{! Tailoring Toggle }}
    <div class="profession-table-toggle tailoring-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showTailoringTable" {{checked system.details.showTailoringTable}} data-dtype="Boolean" data-tailoring-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-cut" style="color: #9c27b0;"></i>
        {{localize "CARDIGAN.ShowTailoringTable"}}
      </label>
    </div>
    
    {{! Tecnomagic Toggle }}
    <div class="profession-table-toggle tecnomagic-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showTecnomagicTable" {{checked system.details.showTecnomagicTable}} data-dtype="Boolean" data-tecnomagic-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-magic" style="color: #2196f3;"></i>
        {{localize "CARDIGAN.ShowTecnomagicTable"}}
      </label>
    </div>
    
    {{! Blacksmithing Toggle }}
    <div class="profession-table-toggle blacksmithing-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showBlacksmithingTable" {{checked system.details.showBlacksmithingTable}} data-dtype="Boolean" data-blacksmithing-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-hammer" style="color: #795548;"></i>
        {{localize "CARDIGAN.ShowBlacksmithingTable"}}
      </label>
    </div>
    
    {{! Alchemy Toggle }}
    <div class="profession-table-toggle alchemy-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showAlchemyTable" {{checked system.details.showAlchemyTable}} data-dtype="Boolean" data-alchemy-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-flask" style="color: #4caf50;"></i>
        {{localize "CARDIGAN.ShowAlchemyTable"}}
      </label>
    </div>
    
    {{! Carpentry Toggle }}
    <div class="profession-table-toggle carpentry-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showCarpentryTable" {{checked system.details.showCarpentryTable}} data-dtype="Boolean" data-carpentry-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-tools" style="color: #8bc34a;"></i>
        {{localize "CARDIGAN.ShowCarpentryTable"}}
      </label>
    </div>
  </div>

  {{! SKILL CLASS TABLES - All skill tables by class }}
  
  {{! Andarilho Skills Table }}
  <div class="skill-table-container andarilho-skills-table-container {{#unless system.details.showSkillsAndarilhoTable}}hidden{{/unless}}" data-andarilho-skills-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #8bc34a; text-align: center;">
      <i class="fas fa-hiking" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.AndarilhoSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-type'>Type</div>
        <div class='item-enhancements'>Enhancements</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Andarilho Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Andarilho Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsAndarilho as |skill id|}}
        <li
          class='item collapsible collapsed skill-item'
          data-item-id='{{skill._id}}'
          data-uuid='{{skill.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Skill Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{skill.img}}' title='{{skill.name}}' width='24' height='24'/>
              </div>
              <div 
                class="skill-name-hover"
                data-tooltip-direction="UP"
                data-tooltip-class="cardigan-tooltip"
                data-item-id="{{skill._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{skill.name}}
                {{#if skill.system.isPassive}}
                  <i class="fas fa-shield-alt" title="{{localize 'CARDIGAN.PassiveSkill'}}" style="color: #4caf50; margin-left: 5px;"></i>
                {{/if}}
              </div>
            </div>
            <div class='item-type'>
              {{#if skill.system.skillType}}
                <span class="skill-type-badge" style="padding: 2px 8px; border-radius: 4px; font-size: 11px; background: rgba(33,150,243,0.2); color: #2196f3;">
                  {{lookup @root.config.skillTypes skill.system.skillType}}
                </span>
              {{/if}}
            </div>
            <div class='item-enhancements'>
              <div class="enhancement-checkboxes" style="display: flex; gap: 8px; justify-content: center;">
                <input type="checkbox" name="system.acquiredEnhancements.0" {{checked skill.system.acquiredEnhancements.0}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 1" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.1" {{checked skill.system.acquiredEnhancements.1}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 2" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.2" {{checked skill.system.acquiredEnhancements.2}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 3" style="width: 18px; height: 18px; cursor: pointer;" />
              </div>
            </div>
            <div class='item-controls'>
              <a class='item-control skill-chat' title='{{localize "CARDIGAN.ShowInChat"}}' data-action='skillToChat' data-item-id='{{skill._id}}'>
                <i class='fas fa-comment'></i>
              </a>
              {{#if @root.editable}}
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
                <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                  <i class='fas fa-trash'></i>
                </a>
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-hiking" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #8bc34a;"></i>
            <p>No Andarilho skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Andarilho skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

  {{! Guerreiro Skills Table }}
  <div class="skill-table-container guerreiro-skills-table-container {{#unless system.details.showSkillsGuerreiroTable}}hidden{{/unless}}" data-guerreiro-skills-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #f44336; text-align: center;">
      <i class="fas fa-sword" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.GuerreiroSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Guerreiro Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Guerreiro Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsGuerreiro as |skill id|}}
        <li
          class='item collapsible collapsed skill-item'
          data-item-id='{{skill._id}}'
          data-uuid='{{skill.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Skill Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{skill.img}}' title='{{skill.name}}' width='24' height='24'/>
              </div>
              <div 
                class="skill-name-hover"
                data-tooltip-direction="UP"
                data-tooltip-class="cardigan-tooltip"
                data-item-id="{{skill._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{skill.name}}
                {{#if skill.system.isPassive}}
                  <i class="fas fa-shield-alt" title="{{localize 'CARDIGAN.PassiveSkill'}}" style="color: #4caf50; margin-left: 5px;"></i>
                {{/if}}
              </div>
            </div>
            <div class='item-controls'>
              <a class='item-control skill-chat' title='{{localize "CARDIGAN.ShowInChat"}}' data-action='skillToChat' data-item-id='{{skill._id}}'>
                <i class='fas fa-comment'></i>
              </a>
              {{#if @root.editable}}
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
                <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                  <i class='fas fa-trash'></i>
                </a>
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-sword" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #f44336;"></i>
            <p>No Guerreiro skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Guerreiro skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

  {{! Ladino Skills Table }}
  <div class="skill-table-container ladino-skills-table-container {{#unless system.details.showSkillsLadinoTable}}hidden{{/unless}}" data-ladino-skills-table-section style="margin-bottom: 20px;">
