      <i class="fas fa-mask" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.LadinoSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Ladino Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Ladino Skill'>
