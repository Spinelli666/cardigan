{{! Features Tab }}
<section
  class='tab features {{tab.cssClass}}'
  data-group='primary'
  data-tab='features'
>
  <section class='main features-tab-main'>
    {{! Grid principal com duas colunas para Character Details/Features e Container Teste }}
    <div class='features-main-grid'>
      {{! Coluna esquerda - Apenas Character Details }}
      <div class='features-left-column'>
        {{! Character Details Container }}
        <div class='character-details-container'>
          <h3>Character Details</h3>
          
          {{! Nome }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.name.label"}}:</label>
            <input
              type='text'
              name='system.details.name'
              value='{{system.details.name}}'
            />
          </div>
          
          {{! Idade }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.age.label"}}:</label>
            <input
              type='number'
              name='system.details.age'
              value='{{system.details.age}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          
          {{! Raça - Drag & Drop Slot }}
          <div class='detail-field race-slot-container'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.race.label"}}:</label>
            <div class='race-drop-zone' data-item-type='race'>
              {{#if raceItem}}
                {{! Race item exists - show it }}
                <div class='race-item-display' data-item-id='{{raceItem._id}}' data-drag='true' data-document-class='Item'>
                  <img src='{{raceItem.img}}' alt='{{raceItem.name}}' class='race-item-image' />
                  <span class='race-item-name'>{{raceItem.name}}</span>
                  {{#if @root.editable}}
                    <a class='race-item-delete' data-action='deleteDoc' data-document-class='Item' data-id='{{raceItem._id}}' title='Remove Race'>
                      <i class='fas fa-times'></i>
                    </a>
                  {{/if}}
                </div>
              {{else}}
                {{! No race item - show drop placeholder }}
                <div class='race-placeholder'>
                  <i class='fas fa-user'></i>
                  <span>Arraste uma raça aqui</span>
                </div>
              {{/if}}
            </div>
          </div>
        </div>
      </div>

      {{! Container Classes - Coluna direita }}
      <div class='container-teste'>
        <h3>Classes</h3>
        
        {{! Classes Row }}
        <div class='classes-row'>
          <div class='class-field'>
            <label>ANDARILHO</label>
            <input
              type='number'
              name='system.classes.andarilho'
              value='{{system.classes.andarilho}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>GUERREIRO</label>
            <input
              type='number'
              name='system.classes.guerreiro'
              value='{{system.classes.guerreiro}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>LADINO</label>
            <input
              type='number'
              name='system.classes.ladino'
              value='{{system.classes.ladino}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>FEITICEIRO</label>
            <input
              type='number'
              name='system.classes.feiticeiro'
              value='{{system.classes.feiticeiro}}'
              data-dtype='Number'
              min='0'
            />
          </div>
        </div>
      </div>
    </div>

    {{! Grid secundário para Status e Abilities lado a lado }}
    <div class='features-secondary-grid'>
      {{! Status Container - Lado esquerdo }}
      <div class='status-container'>
        <h3>Status</h3>
        <div class='status-content'>
          <div class='vida-container horizontal-field'>
            <label class='status-label label-left'>Health:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.health.value'
                value='{{system.health.value}}'
                data-dtype='Number'
                min='0'
                class='status-current dynamic-field'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.health.max'
                value='{{system.health.max}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.status.healthBonus'
                value='{{system.status.healthBonus}}'
                data-dtype='Number'
                class='bonus-input dynamic-field'
                title='Health Bonus'
              />
            </div>
          </div>
          <div class='energia-container horizontal-field'>
            <label class='status-label label-left'>Energy:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.power.value'
                value='{{system.power.value}}'
                data-dtype='Number'
                min='0'
                class='status-current dynamic-field'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.power.max'
                value='{{system.power.max}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.status.energyBonus'
                value='{{system.status.energyBonus}}'
                data-dtype='Number'
                class='bonus-input dynamic-field'
                title='Energy Bonus'
              />
            </div>
          </div>
          
          <!-- Fome e Sede -->
          <div class='fome-sede-container'>
            <div class='hunger-row horizontal-field'>
              <label class='status-label label-left'>Hunger:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetHunger'
                title='Reset Hunger'
              >
                ↻
              </button>
              <div class='radio-group' data-field='hunger'>
                <input type='hidden' name='system.status.hunger' value='{{system.status.hunger}}' data-dtype='Number' />
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='hunger-1'
                    data-level='1'
                    {{#if (gte system.status.hunger 1)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='hunger-2'
                    data-level='2'
                    {{#if (gte system.status.hunger 2)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='hunger-3'
                    data-level='3'
                    {{#if (gte system.status.hunger 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <div class='thirst-row horizontal-field'>
              <label class='status-label label-left'>Thirst:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetThirst'
                title='Reset Thirst'
              >
                ↻
              </button>
              <div class='radio-group' data-field='thirst'>
                <input type='hidden' name='system.status.thirst' value='{{system.status.thirst}}' data-dtype='Number' />
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='thirst-1'
                    data-level='1'
                    {{#if (gte system.status.thirst 1)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='thirst-2'
                    data-level='2'
                    {{#if (gte system.status.thirst 2)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='checkbox'
                    name='thirst-3'
                    data-level='3'
                    {{#if (gte system.status.thirst 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Fratura -->
            <div class='fracture-row horizontal-field'>
              <label class='status-label label-left'>Fracture:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetFracture'
                title='Reset Fracture'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='fracture'>
                <input type='hidden' name='system.status.fracture' value='{{system.status.fracture}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.fracture 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.fracture 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.fracture 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.fracture 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.fracture 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Sanidade -->
            <div class='sanity-row horizontal-field'>
              <label class='status-label label-left'>Sanity:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetSanity'
                title='Reset Sanity'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='sanity'>
                <input type='hidden' name='system.status.sanity' value='{{system.status.sanity}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.sanity 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.sanity 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.sanity 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.sanity 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.sanity 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Toxicity -->
            <div class='toxicity-row horizontal-field'>
              <label class='status-label label-left'>Toxicity:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetToxicity'
                title='Reset Toxicity'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='toxicity'>
                <input type='hidden' name='system.status.toxicity' value='{{system.status.toxicity}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.toxicity 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.toxicity 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.toxicity 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.toxicity 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.toxicity 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>

          </div>
        </div>
      </div>

      {{! Abilities Container - Lado direito }}
      <div class='abilities-main-container'>
        <div class='abilities-header'>
          <h3>Abilities</h3>
        </div>
        <div class='abilities-list'>
          {{#each system.abilities as |ability key|}}
            <div class='ability-row horizontal-field'>
              <label>{{localize (lookup @root.config.abilities key)}}</label>
              <div class='status-display'>
                <input
                  type='number'
                  name='system.abilities.{{key}}.value'
                  value='{{ability.value}}'
                  data-dtype='Number'
                  class='ability-value dynamic-field'
                  data-ability='{{key}}'
                  data-field='value'
                  title='Base Value (Focus: manual | Blur: total)'
                />
              </div>
              <div class='bonus-container'>
                <input
                  type='number'
                  name='system.abilities.{{key}}.totalBonus'
                  value='{{ability.totalBonus}}'
                  data-dtype='Number'
                  class='bonus-input dynamic-field'
                  data-ability='{{key}}'
                  data-field='totalBonus'
                  title='Total Bonus (Focus: manual | Blur: calculated + manual)'
                />
              </div>
              <div class='roll-button-container'>
                <button 
                  type='button' 
                  class='ability-roll-button'
                  data-action='roll'
                  data-roll='1d20+@{{key}}.total'
                  data-label='{{localize (lookup @root.config.abilities key)}} ({{ability.value}}+{{ability.totalBonus}}={{add ability.value ability.totalBonus}})'
                  data-key='{{key}}'
                >
                  Roll 1d20
                </button>
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{! Grid quaternário para Additional Notes e Effects lado a lado }}
    <div class='features-quaternary-grid'>
      {{! Additional Notes Container - Lado esquerdo }}
      <div class='additional-notes-container'>
        <div class="additional-notes-header">
          <h3>Additional Notes</h3>
          <div class="additional-notes-toggle">
            <label>
              <input
                type="checkbox"
                name="system.details.showAdditionalNotes"
                {{#if system.details.showAdditionalNotes}}checked{{/if}}
                data-dtype="Boolean"
              />
              Show Additional Notes
            </label>
          </div>
        </div>
        {{#if system.details.showAdditionalNotes}}
          <section class='additional-notes-editor'>
            <textarea
              name="system.details.additionalNotes"
              rows="6"
              placeholder="Digite suas notas adicionais aqui..."
            >{{system.details.additionalNotes}}</textarea>
          </section>
        {{/if}}
      </div>

      {{! Effects Container - Lado direito }}
      <div class='effects-container'>
        <div class="effects-header">
          <h3>{{localize "CARDIGAN.Effect.Effects"}}</h3>
          <div class="effects-toggle">
            <label>
              <input
                type="checkbox"
                name="system.details.showEffectsTab"
                {{#if system.details.showEffectsTab}}checked{{/if}}
                data-dtype="Boolean"
              />
              {{localize "CARDIGAN.Tabs.ShowEffects"}}
            </label>
          </div>
          {{#if system.details.showEffectsTab}}
            <div class='effect-controls'>
            </div>
          {{/if}}
        </div>
        
        {{#if system.details.showEffectsTab}}
          {{! Unified Effects List - ActiveEffects and Items together }}
          {{! ActiveEffects are filtered to hide duplicates of Item efeitos }}
          <ol class='effects-list'>
            {{#each filteredEffects as |effect|}}
              <li
                class='effect flexrow'
                data-effect-id='{{effect.id}}'
                data-document-class='ActiveEffect'
              >
                <div class='effect-image'>
                  <img src='{{effect.img}}' alt='{{effect.name}}' width='24' height='24' />
                </div>
                
                <div class='effect-name'>
                  <h4 
                    data-tooltip="{{effect.name}}{{#if effect.flags.cardigan.descriptionPlainText}}<br><em>{{effect.flags.cardigan.descriptionPlainText}}</em>{{/if}}"
                    data-tooltip-direction="UP"
                    data-tooltip-class="cardigan-tooltip"
                    data-action="showEffectInChat"
                    data-effect-name="{{effect.name}}"
                    data-effect-description="{{effect.flags.cardigan.description}}"
                    class="clickable-effect"
                  >
                    {{effect.name}}
                    {{#if effect.disabled}}<em> (Disabled)</em>{{/if}}
                  </h4>
                </div>

                <div class='effect-controls flexrow'>
                  {{#if @root.editable}}
                  <a class='effect-control' data-action='deleteDoc' title='Delete Effect'>
                    <i class='fas fa-trash'></i>
                  </a>
                  {{/if}}
                </div>
              </li>
            {{/each}}

            {{#each efeitos as |efeito|}}
              <li
                class='effect flexrow'
                data-item-id='{{efeito.id}}'
                data-document-class='Item'
                data-drag="true"
              >
                <div class='effect-image'>
                  <img src='{{efeito.img}}' alt='{{efeito.name}}' width='24' height='24' />
                </div>
                
                <div class='effect-name'>
                  <h4 
                    data-tooltip-class="cardigan-tooltip effect-tooltip"
                    data-action="showEffectInChat"
                    data-effect-name="{{efeito.name}}"
                    data-effect-description="{{efeito.system.description}}"
                    class="clickable-effect effect-item"
                    data-item-uuid="{{efeito.uuid}}"
                  >
                    {{efeito.name}}
                  </h4>
                </div>

                <div class='effect-controls flexrow'>
                  {{#if @root.editable}}
                  <a class='effect-control' data-action='deleteDoc' title='Delete Efeito'>
                    <i class='fas fa-trash'></i>
                  </a>
                  {{/if}}
                </div>
              </li>
            {{/each}}

            {{#unless filteredEffects.length}}
              {{#unless efeitos}}
              <li class="no-effects">
                <span>No effects available</span>
              </li>
              {{/unless}}
            {{/unless}}
          </ol>
        {{/if}}
      </div>
    </div>    

    {{! Grid terciário para Features List }}
    <div class='features-tertiary-grid'>
      {{! Features Container - Largura completa }}
      <div class='features-container'>
      </div>
    </div>
  </section>

  {{! Abilities Edit Modal }}
  <div id='abilities-edit-modal' class='abilities-modal' style='display: none;'>
    <div class='modal-content'>
      <div class='modal-header'>
        <h3>Edit Abilities</h3>
        <button type='button' class='close-modal' data-action='closeAbilitiesModal'>
          <i class="fas fa-times"></i>
        </button>
      </div>
      <div class='modal-body'>
        {{#each system.abilities as |ability key|}}
          <div class='ability-edit-row'>
            <label>{{localize (lookup @root.config.abilities key)}}</label>
            <div class='ability-edit-fields'>
              <div class='field-group'>
                <label class='field-label'>Base Value</label>
                <input
                  type='number'
                  value='{{ability.value}}'
                  data-dtype='Number'
                  class='ability-value-edit'
                  data-ability='{{key}}'
                />
              </div>
              <div class='field-group'>
                <label class='field-label'>Bonus</label>
                <input
                  type='number'
                  value='{{ability.bonus}}'
                  data-dtype='Number'
                  class='ability-bonus-edit'
                  data-ability='{{key}}'
                />
              </div>
              <div class='field-group'>
                <label class='field-label'>Total</label>
                <span class='ability-total'>{{ability.total}}</span>
              </div>
            </div>
          </div>
        {{/each}}
      </div>
      <div class='modal-footer'>
        <button type='button' class='close-modal' data-action='closeAbilitiesModal'>
          Close
        </button>
      </div>
    </div>
  </div>
</section>