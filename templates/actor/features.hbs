{{! Features Tab }}
<section
  class='tab features {{tab.cssClass}}'
  data-group='primary'
  data-tab='features'
>
  <section class='main features-tab-main'>
    {{! Grid principal com duas colunas para Character Details/Features e Container Teste }}
    <div class='features-main-grid'>
      {{! Coluna esquerda - Apenas Character Details }}
      <div class='features-left-column'>
        {{! Character Details Container }}
        <div class='character-details-container'>
          <h3>Character Details</h3>
          
          {{! Nome }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.name.label"}}:</label>
            <input
              type='text'
              name='system.details.name'
              value='{{system.details.name}}'
            />
          </div>
          
          {{! Idade }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.age.label"}}:</label>
            <input
              type='number'
              name='system.details.age'
              value='{{system.details.age}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          
          {{! Raça }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.race.label"}}:</label>
            <input
              type='text'
              name='system.details.race'
              value='{{system.details.race}}'
            />
          </div>
          
          {{! Deslocamento }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.movement.label"}}:</label>
            <input
              type='number'
              name='system.details.movement'
              value='{{system.details.movement}}'
              data-dtype='Number'
              min='0'
              readonly
            />
          </div>
          
          {{! Acerto Crítico }}
          <div class='detail-field'>
            <label>{{localize "CARDIGAN.Actor.base.FIELDS.details.criticalHit.label"}}:</label>
            <input
              type='number'
              name='system.details.criticalHit'
              value='{{system.details.criticalHit}}'
              data-dtype='Number'
              readonly
            />
          </div>
        </div>
      </div>

      {{! Container Classes, XP & Levels - Coluna direita }}
      <div class='container-teste'>
        <h3>Classes, XP & Levels</h3>
        
        {{! XP e Level Container }}
        <div class='xp-level-container'>
          <div class='xp-container'>
            <label class='status-label'>XP:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.experience.current'
                value='{{system.experience.current}}'
                data-dtype='Number'
                min='0'
                class='status-current'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.experience.nextLevel'
                value='{{system.experience.nextLevel}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
          </div>
          
          <div class='level-container'>
            <label class='level-label'>Level:</label>
            <div class='level-display'>
              <input
                type='number'
                name='system.attributes.level.value'
                value='{{system.attributes.level.value}}'
                data-dtype='Number'
                min='1'
                class='level-input'
                readonly
              />
            </div>
          </div>
        </div>
        
        {{! Classes Row }}
        <div class='classes-row'>
          <div class='class-field'>
            <label>ANDARILHO</label>
            <input
              type='number'
              name='system.classes.andarilho'
              value='{{system.classes.andarilho}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>GUERREIRO</label>
            <input
              type='number'
              name='system.classes.guerreiro'
              value='{{system.classes.guerreiro}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>LADINO</label>
            <input
              type='number'
              name='system.classes.ladino'
              value='{{system.classes.ladino}}'
              data-dtype='Number'
              min='0'
            />
          </div>
          <div class='class-field'>
            <label>FEITICEIRO</label>
            <input
              type='number'
              name='system.classes.feiticeiro'
              value='{{system.classes.feiticeiro}}'
              data-dtype='Number'
              min='0'
            />
          </div>
        </div>
      </div>
    </div>

    {{! Grid secundário para Status e Abilities lado a lado }}
    <div class='features-secondary-grid'>
      {{! Status Container - Lado esquerdo }}
      <div class='status-container'>
        <h3>Status</h3>
        <div class='status-content'>
          <div class='vida-container horizontal-field'>
            <label class='status-label label-left'>Health:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.health.value'
                value='{{system.health.value}}'
                data-dtype='Number'
                min='0'
                class='status-current'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.health.max'
                value='{{system.health.max}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.status.healthBonus'
                value='{{system.status.healthBonus}}'
                data-dtype='Number'
                class='bonus-input'
                title='Health Bonus'
              />
            </div>
          </div>
          <div class='energia-container horizontal-field'>
            <label class='status-label label-left'>Energy:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.power.value'
                value='{{system.power.value}}'
                data-dtype='Number'
                min='0'
                class='status-current'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.power.max'
                value='{{system.power.max}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.status.energyBonus'
                value='{{system.status.energyBonus}}'
                data-dtype='Number'
                class='bonus-input'
                title='Energy Bonus'
              />
            </div>
          </div>
          <div class='armadura-container horizontal-field'>
            <label class='status-label label-left'>Armor:</label>
            <div class='status-display'>
              <input
                type='number'
                name='system.armor.value'
                value='{{system.armor.value}}'
                data-dtype='Number'
                min='0'
                class='status-current'
              />
              <span class='status-separator'>/</span>
              <input
                type='number'
                name='system.armor.max'
                value='{{system.armor.max}}'
                data-dtype='Number'
                min='0'
                class='status-next'
                readonly
              />
            </div>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.status.armorBonus'
                value='{{system.status.armorBonus}}'
                data-dtype='Number'
                class='bonus-input'
                title='Armor Bonus'
              />
            </div>
          </div>
          <!-- Fome e Sede -->
          <div class='fome-sede-container'>
            <div class='hunger-row horizontal-field'>
              <label class='status-label label-left'>Hunger:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetHunger'
                title='Reset Hunger'
              >
                ↻
              </button>
              <div class='radio-group' data-field='hunger'>
                <input type='hidden' name='system.status.hunger' value='{{system.status.hunger}}' data-dtype='Number' />
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='hunger-1'
                    data-level='1'
                    {{#if (gte system.status.hunger 1)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='hunger-2'
                    data-level='2'
                    {{#if (gte system.status.hunger 2)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='hunger-3'
                    data-level='3'
                    {{#if (gte system.status.hunger 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <div class='thirst-row horizontal-field'>
              <label class='status-label label-left'>Thirst:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetThirst'
                title='Reset Thirst'
              >
                ↻
              </button>
              <div class='radio-group' data-field='thirst'>
                <input type='hidden' name='system.status.thirst' value='{{system.status.thirst}}' data-dtype='Number' />
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='thirst-1'
                    data-level='1'
                    {{#if (gte system.status.thirst 1)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='thirst-2'
                    data-level='2'
                    {{#if (gte system.status.thirst 2)}}checked{{/if}}
                  />
                </label>
                <label class='radio-option'>
                  <input
                    type='radio'
                    name='thirst-3'
                    data-level='3'
                    {{#if (gte system.status.thirst 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Exaustão -->
            <div class='exhaustion-row horizontal-field'>
              <label class='status-label label-left'>Exhaustion:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetExhaustion'
                title='Reset Exhaustion'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='exhaustion'>
                <input type='hidden' name='system.status.exhaustion' value='{{system.status.exhaustion}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.exhaustion 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.exhaustion 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.exhaustion 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.exhaustion 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.exhaustion 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Fratura -->
            <div class='fracture-row horizontal-field'>
              <label class='status-label label-left'>Fracture:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetFracture'
                title='Reset Fracture'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='fracture'>
                <input type='hidden' name='system.status.fracture' value='{{system.status.fracture}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.fracture 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.fracture 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.fracture 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.fracture 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.fracture 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Sanidade -->
            <div class='sanity-row horizontal-field'>
              <label class='status-label label-left'>Sanity:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetSanity'
                title='Reset Sanity'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='sanity'>
                <input type='hidden' name='system.status.sanity' value='{{system.status.sanity}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.sanity 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.sanity 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.sanity 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.sanity 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.sanity 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Toxicity -->
            <div class='toxicity-row horizontal-field'>
              <label class='status-label label-left'>Toxicity:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetToxicity'
                title='Reset Toxicity'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='toxicity'>
                <input type='hidden' name='system.status.toxicity' value='{{system.status.toxicity}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.toxicity 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.toxicity 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.toxicity 3)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='4'
                    {{#if (gte system.status.toxicity 4)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='5'
                    {{#if (gte system.status.toxicity 5)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Gift of Life -->
            <div class='gift-of-life-row horizontal-field'>
              <label class='status-label label-left'>Gift of Life:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetGiftOfLife'
                title='Reset Gift of Life'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='giftOfLife'>
                <input type='hidden' name='system.status.giftOfLife' value='{{system.status.giftOfLife}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.giftOfLife 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.giftOfLife 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.giftOfLife 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Death Sentence -->
            <div class='death-sentence-row horizontal-field'>
              <label class='status-label label-left'>Death Sentence:</label>
              <button 
                type='button' 
                class='reset-button'
                data-action='resetDeathSentence'
                title='Reset Death Sentence'
              >
                ↻
              </button>
              <div class='sequential-group' data-field='deathSentence'>
                <input type='hidden' name='system.status.deathSentence' value='{{system.status.deathSentence}}' data-dtype='Number' />
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='1'
                    {{#if (gte system.status.deathSentence 1)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='2'
                    {{#if (gte system.status.deathSentence 2)}}checked{{/if}}
                  />
                </label>
                <label class='sequential-option'>
                  <input
                    type='checkbox'
                    data-level='3'
                    {{#if (gte system.status.deathSentence 3)}}checked{{/if}}
                  />
                </label>
              </div>
            </div>
            <!-- Death Die -->
            <div class='death-die-row horizontal-field'>
              <label class='status-label label-left'>Death Die:</label>
              <div class='death-die-button-container'>
                <button 
                  type='button' 
                  class='death-die-button'
                  data-action='rollDeathDie'
                  data-roll='1d12'
                  data-label='Death Die'
                >
                  Roll 1d12
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>

      {{! Abilities Container - Lado direito }}
      <div class='abilities-main-container'>
        <h3>Abilities</h3>
        <div class='abilities-list'>
          {{#each system.abilities as |ability key|}}
            <div class='ability-row horizontal-field'>
              <label>{{localize (lookup @root.config.abilities key)}}</label>
              <div class='status-display'>
                <input
                  type='text'
                  name='system.abilities.{{key}}.value'
                  value='{{ability.value}}'
                  data-dtype='Number'
                  class='ability-value'
                  title='Base Value'
                />
              </div>
              <div class='bonus-container'>
                <input
                  type='number'
                  name='system.abilities.{{key}}.bonus'
                  value='{{ability.bonus}}'
                  data-dtype='Number'
                  class='bonus-input'
                  title='{{localize (lookup @root.config.abilities key)}} Bonus'
                />
              </div>
              <div class='roll-button-container'>
                <button 
                  type='button' 
                  class='ability-roll-button'
                  data-action='roll'
                  data-roll='1d20+@{{key}}.value'
                  data-label='{{localize (lookup @root.config.abilities key)}} ({{ability.value}}+{{ability.bonus}}={{ability.total}})'
                  data-key='{{key}}'
                >
                  Roll 1d20
                </button>
              </div>
            </div>
          {{/each}}
        </div>
      </div>
    </div>

    {{! Grid quaternário para Additional Notes }}
    <div class='features-quaternary-grid'>
      {{! Additional Notes Container - Largura completa }}
      <div class='additional-notes-container'>
        <div class="additional-notes-header">
          <h3>Additional Notes</h3>
          <div class="additional-notes-toggle">
            <label>
              <input
                type="checkbox"
                name="system.details.showAdditionalNotes"
                {{#if system.details.showAdditionalNotes}}checked{{/if}}
                data-dtype="Boolean"
              />
              Show Additional Notes
            </label>
          </div>
        </div>
        {{#if system.details.showAdditionalNotes}}
          <section class='additional-notes-editor'>
            {{#if editable}}
              <prose-mirror 
                name="system.details.additionalNotes" 
                data-document-u-u-i-d="{{actor.uuid}}" 
                value="{{system.details.additionalNotes}}" 
                collaborate="true" 
                toggled="true">
                {{{enrichedAdditionalNotes}}}
              </prose-mirror>
            {{else}}
              <div class="editor-content">
                {{{enrichedAdditionalNotes}}}
              </div>
            {{/if}}
          </section>
        {{/if}}
      </div>
    </div>    

    {{! Grid terciário para Features List }}
    <div class='features-tertiary-grid'>
      {{! Features Container - Largura completa }}
      <div class='features-container'>
        <h3>Features</h3>
        <ol class='items-list'>
          <li class='item flexrow items-header'>
            <div class='item-name'>{{localize 'Name'}}</div>
            <div class='item-controls'>
              {{#if @root.editable}}
                <a
                  class='item-control item-create'
                  title='Create item'
                  data-action='createDoc'
                  data-document-class='Item'
                  data-type='feature'
                >
                  <i class='fas fa-plus'></i>
                  {{localize 'DOCUMENT.New' type='feature'}}
                </a>
              {{/if}}
            </div>
          </li>
          {{#each features as |item id|}}
            <li
              class='item flexrow'
              data-item-id='{{item._id}}'
              data-drag='true'
              data-document-class='Item'
            >
              <div class='item-name'>
                <div class='item-image'>
                  <a class='rollable' data-roll-type='item' data-action='roll'>
                    <img
                      src='{{item.img}}'
                      title='{{item.name}}'
                      width='24'
                      height='24'
                    />
                  </a>
                </div>
                <div>{{item.name}}</div>
              </div>
              <div class='item-controls'>
                <a
                  class='item-control item-edit'
                  title='{{localize "DOCUMENT.Update" type='feature'}}'
                  data-action='viewDoc'
                >
                  <i class='fas fa-edit'></i>
                </a>
                {{#if @root.editable}}
                  <a
                    class='item-control item-delete'
                    title='{{localize "DOCUMENT.Delete" type='feature'}}'
                    data-action='deleteDoc'
                  >
                    <i class='fas fa-trash'></i>
                  </a>
                {{/if}}
              </div>
            </li>
          {{/each}}
        </ol>
      </div>
    </div>
  </section>
</section>