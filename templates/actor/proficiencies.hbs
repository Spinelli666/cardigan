{{! proficiencies Tab }}
<section
  class='tab proficiencies {{tab.cssClass}}'
  data-group='primary'
  data-tab='proficiencies'
>
  <section class='main proficiencies-tab-main'>
    {{! Proficiencies }}
    <div class='proficiencies'>
      {{! Combat Proficiencies - Accuracy & Evasion }}
      <div class='combat-proficiencies-container'>
        <img src='systems/cardigan/assets/images/decorative/accuracy-attack.webp' class='accuracy-attack-image' alt='Accuracy Attack' />
        <div class='proficiencies-list'>
          <div class='proficiency-item'>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.abilities.accuracy.totalBonus'
                value='{{system.abilities.accuracy.totalBonus}}'
                data-dtype='Number'
                class='bonus-input dynamic-field'
                data-ability='accuracy'
                data-field='totalBonus'
              />
            </div>
            <div class='status-display'>
              <input
                type='number'
                name='system.abilities.accuracy.value'
                value='{{system.abilities.accuracy.value}}'
                data-dtype='Number'
                class='ability-value dynamic-field'
                data-ability='accuracy'
                data-field='value'
              />
              <img src='systems/cardigan/assets/images/decorative/icons/icon-d20.svg' class='d20-icon' alt='d20' />
            </div>
          </div>
          <div class='proficiency-label-wrapper'>
            <label>{{localize "CARDIGAN.Ability.Accuracy.long"}}</label>
            <div class='proficiency-tooltip'>
              <div class='tooltip-preview'><span class='tooltip-highlight'>PRECISÃO</span></div>
              <div class='tooltip-expanded'>
                <img src='systems/cardigan/assets/images/decorative/divider.webp' class='divider-left' alt='Divider Left' />
                <img src='systems/cardigan/assets/images/decorative/divider.webp' class='divider-right' alt='Divider Right' />
                <div class='tooltip-title'><span class='tooltip-highlight'>PRECISÃO</span></div>
              </div>
            </div>
          </div>
        </div>
        <div class='proficiencies-list'>
          <div class='proficiency-item'>
            <div class='bonus-container'>
              <input
                type='number'
                name='system.abilities.evasion.totalBonus'
                value='{{system.abilities.evasion.totalBonus}}'
                data-dtype='Number'
                class='bonus-input dynamic-field'
                data-ability='evasion'
                data-field='totalBonus'
              />
            </div>
            <div class='status-display'>
              <input
                type='number'
                name='system.abilities.evasion.value'
                value='{{system.abilities.evasion.value}}'
                data-dtype='Number'
                class='ability-value dynamic-field'
                data-ability='evasion'
                data-field='value'
              />
              <img src='systems/cardigan/assets/images/decorative/icons/icon-d20.svg' class='d20-icon' alt='d20' />
            </div>
          </div>
          <div class='proficiency-label-wrapper'>
            <label>{{localize "CARDIGAN.Ability.Evasion.long"}}</label>
            <div class='proficiency-tooltip'>
              <div class='tooltip-preview'><span class='tooltip-highlight'>EVASÃO</span></div>
              <div class='tooltip-expanded'>
                <img src='systems/cardigan/assets/images/decorative/divider.webp' class='divider-left' alt='Divider Left' />
                <img src='systems/cardigan/assets/images/decorative/divider.webp' class='divider-right' alt='Divider Right' />
                <div class='tooltip-title'><span class='tooltip-highlight'>EVASÃO</span></div>
              </div>
            </div>
          </div>
        </div>
        <img src='systems/cardigan/assets/images/decorative/evasion-defense.webp' class='evasion-defense-image' alt='Evasion Defense' />
      </div>

