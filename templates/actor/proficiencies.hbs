{{! proficiencies Tab }}
<section
  class='tab proficiencies {{tab.cssClass}}'
  data-group='primary'
  data-tab='proficiencies'
>
  <img src='systems/cardigan/assets/images/decorative/divider.webp' class='proficiencies-divider-top-left' alt='Divider' />
  <img src='systems/cardigan/assets/images/decorative/divider.webp' class='proficiencies-divider-top-right' alt='Divider' />
  <section class='main proficiencies-tab-main'>
    {{! Proficiencies }}
    <div class='proficiencies'>
      {{! Combat Proficiencies - Accuracy & Evasion }}
      <div class='combat-proficiencies-container'>
        <img src='systems/cardigan/assets/images/decorative/accuracy-attack.webp' class='accuracy-attack-image' alt='Accuracy Attack' />
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="accuracy" abilityData=system.abilities.accuracy labelPrefix="CARDIGAN.Ability.Accuracy"}}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="evasion" abilityData=system.abilities.evasion labelPrefix="CARDIGAN.Ability.Evasion"}}
        <img src='systems/cardigan/assets/images/decorative/evasion-defense.webp' class='evasion-defense-image' alt='Evasion Defense' />
      </div>

      {{! Attribute Proficiencies - Strength, Dexterity, Stamina, etc }}
      <div class='attribute-proficiencies-container'>
        {{! Strength }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="strength" abilityData=system.abilities.strength labelPrefix="CARDIGAN.Ability.Strength"}}

        {{! Dexterity }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="dexterity" abilityData=system.abilities.dexterity labelPrefix="CARDIGAN.Ability.Dexterity"}}

        {{! Stamina }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="stamina" abilityData=system.abilities.stamina labelPrefix="CARDIGAN.Ability.Stamina"}}

        {{! Stealth }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="stealth" abilityData=system.abilities.stealth labelPrefix="CARDIGAN.Ability.Stealth"}}

        {{! Persuasion }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="persuasion" abilityData=system.abilities.persuasion labelPrefix="CARDIGAN.Ability.Persuasion"}}

        {{! Intelligence }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="intelligence" abilityData=system.abilities.intelligence labelPrefix="CARDIGAN.Ability.Intelligence"}}

        {{! Psionics }}
        {{> "systems/cardigan/templates/actor/partials/proficiency-item.hbs" ability="psionics" abilityData=system.abilities.psionics labelPrefix="CARDIGAN.Ability.Psionics"}}
      </div>
  </section>

  {{! Effects Grid }}
  <div class='proficiencies-effects-grid'>
    {{! Effects Container }}
    <div class='proficiencies-effects-container'>
      <div class="effects-header">
        <div class="effects-toggle" >
          <input
            type="checkbox"
            name="system.details.showEffectsTab"
            {{#if system.details.showEffectsTab}}checked{{/if}}
            data-dtype="Boolean"
            style="display: none;"
          />
          <img 
            src="systems/cardigan/assets/images/effects/effects.webp" 
            alt="Toggle Effects" 
            class="effects-toggle-icon"
            data-action="toggleEffectsSection"
            data-tooltip='CARDIGAN.Tooltip.Effects' 
            data-tooltip-class='cardigan-tooltip'
          />
        </div>
        {{#if system.details.showEffectsTab}}
          <div class='effect-controls'>
          </div>
        {{/if}}
      </div>
      
      {{#if system.details.showEffectsTab}}
        <div class="effects-content-wrapper">
          <div class="add-effect-button-container" data-tooltip='CARDIGAN.Tooltip.AddEffects' data-tooltip-class='cardigan-tooltip'>
            <img 
              src="systems/cardigan/assets/images/decorative/icons/icon-add-effects.svg" 
              alt="Add Effect" 
              class="add-effect-icon"
              data-action="openEffectsSelection"
            />
          </div>
          {{! Unified Effects List - ActiveEffects and Items together }}
          {{! ActiveEffects are filtered to hide duplicates of Item efeitos }}
          <ol class='effects-list'>
          {{#each filteredEffects as |effect|}}
            <li
              class='effect flexrow'
              data-effect-id='{{effect.id}}'
              data-document-class='ActiveEffect'
            >
              <div class='effect-image'>
                <img 
                  src='{{effect.img}}' 
                  alt='{{effect.name}}' 
                  width='24' 
                  height='24'
                  data-action="sendEffectToChat"
                  data-effect-name="{{effect.name}}"
                  data-effect-description="{{effect.flags.cardigan.description}}"
                  data-effect-img="{{effect.img}}"
                  class="effect-image-clickable"
                />
                <div class="chat-icon"></div>
              </div>
              
              <div class='effect-name'>
                <h4               
                  data-action="showEffectInChat"
                  data-effect-name="{{effect.name}}"
                  data-effect-description="{{effect.flags.cardigan.description}}"
                  data-effect-img="{{effect.img}}"
                  data-tooltip-type="effect"
                  data-effect-type="active"
                  class="clickable-effect"
                >
                  {{effect.name}}
                  {{#if effect.disabled}}<em> (Disabled)</em>{{/if}}
                </h4>
              </div>

              <div class='effect-controls flexrow'>
                {{#if @root.editable}}
                <a class='effect-control' data-action='deleteDoc' title='Delete Effect'>
                  <img src='systems/cardigan/assets/images/decorative/icons/icon-delete.svg' alt='Delete' class='delete-icon' width='12' height='12' />
                </a>
                {{/if}}
              </div>
            </li>
          {{/each}}

          {{#each efeitos as |efeito|}}
            <li
              class='effect flexrow'
              data-item-id='{{efeito.id}}'
              data-document-class='Item'
              data-drag="true"
            >
              <div class='effect-image'>
                <img 
                  src='{{efeito.img}}' 
                  alt='{{efeito.name}}' 
                  width='24' 
                  height='24'
                  data-action="sendEffectToChat"
                  data-effect-name="{{efeito.name}}"
                  data-effect-description="{{efeito.system.description}}"
                  data-effect-img="{{efeito.img}}"
                  data-effect-rounds="{{efeito.system.rodadas}}"
                  class="effect-image-clickable"
                />
                <div class="chat-icon"></div>
              </div>
              
              <div class='effect-name'>
                <h4 
                  data-action="showEffectInChat"
                  data-effect-name="{{efeito.name}}"
                  data-effect-description="{{efeito.system.description}}"
                  data-effect-img="{{efeito.img}}"
                  data-tooltip-type="effect"
                  data-effect-type="item"
                  class="clickable-effect effect-item"
                  data-item-uuid="{{efeito.uuid}}"
                >
                  {{efeito.name}}
                </h4>
              </div>

              {{#if efeito.system.consumableTracking.isTrackingEffect}}
              <div class='item-quantity effect-consumed-quantity' data-tooltip='Quantidade consumida' data-tooltip-class='cardigan-tooltip'>
                <input
                  type='number'
                  value='{{efeito.system.consumableTracking.consumedQuantity}}'
                  min='0'
                  data-dtype='Number'
                  readonly
                  aria-label='Quantidade consumida'
                />
              </div>
              {{/if}}

              <div class='effect-rounds'>
                <img src="systems/cardigan/assets/images/decorative/icons/icon-clock.svg" alt="Rodadas" class="rounds-icon" width="16" height="16">
                <span class="rounds-value">{{#if efeito.system.rodadas}}{{#if (eq efeito.system.rodadas "infinito")}}<div class="rounds-infinite-icon"></div>{{else}}{{efeito.system.rodadas}}{{/if}}{{else}}0{{/if}}</span>
              </div>

              <div class='effect-controls flexrow'>
                {{#if @root.editable}}
                <a class='effect-control' data-action='deleteDoc' title='Delete Efeito'>
                  <img src='systems/cardigan/assets/images/decorative/icons/icon-delete.svg' alt='Delete' class='delete-icon' width='12' height='12' />
                </a>
                {{/if}}
              </div>
            </li>
          {{/each}}

          {{#unless filteredEffects.length}}
            {{#unless efeitos}}
            <li class="no-effects">
              <span>Nenhum efeito aplicado</span>
            </li>
            {{/unless}}
          {{/unless}}
        </ol>
        </div>
      {{/if}}
    </div>
  </div>
</section>
