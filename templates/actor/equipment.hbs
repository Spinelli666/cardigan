<section class='tab equipment {{tab.cssClass}}' data-group='primary' data-tab='equipment'>
  
  {{! Money & Business Banner }}
  <div class="money-business-banner">
    <div class="money-inner">
      <img src='systems/cardigan/assets/images/decorative/icons/icon-coins.svg' alt='Moedas' class='money-coin-icon' />
      <div class="money-field-container">
        <input
          type='number'
          name='system.money'
          value='{{system.money}}'
          data-dtype='Number'
          min='0'
          class='money-field'
          data-tooltip='CARDIGAN.Tooltip.Money'
          data-tooltip-class='cardigan-tooltip'
          {{#unless @root.isGM}}disabled{{/unless}}
        />
      </div>
    </div>
    {{#unless (eq actor.type "npc")}}
    <div class="negotiation-container">
      <button type='button' class='negotiate-button' data-action='initiateTrade'
        data-tooltip='CARDIGAN.Tooltip.Negotiate' data-tooltip-class='cardigan-tooltip'>
        <img src='systems/cardigan/assets/images/decorative/icons/icon-negotiation.svg' alt='Negociar' class='negotiate-icon' />
      </button>
    </div>
    {{/unless}}
  </div>

  {{! Inventory Banner }}
  <div class="inventory-banner">
    <div class="backpack-toggle">
      <input
        type="checkbox"
        name="system.details.showBackpackContainer"
        {{#if system.details.showBackpackContainer}}checked{{/if}}
        data-dtype="Boolean"
        style="display: none;"
      />
      <img
        src="systems/cardigan/assets/images/decorative/backpack.svg"
        alt="Toggle Backpack"
        class="backpack-toggle-icon"
        data-action="toggleBackpackContainer"
        data-tooltip='CARDIGAN.Tooltip.Backpack'
        data-tooltip-class='cardigan-tooltip'
      />
    </div>
    <div class='status-display {{#if (gte backpackSpacesOccupied system.backpack.max)}}backpack-full{{/if}}'
      data-tooltip='CARDIGAN.Tooltip.Weight'
      data-tooltip-class='cardigan-tooltip'>
      <input
        type='number'
        name='system.backpack.current'
        value='{{backpackSpacesOccupied}}'
        data-dtype='Number'
        min='0'
        class='status-current {{#if (gte backpackSpacesOccupied system.backpack.max)}}backpack-full-text{{/if}}'
        readonly
      />
      <img
        src='systems/cardigan/assets/images/decorative/field-divider.svg'
        alt='/'
        class='status-separator-icon'
      />
      <input
        type='number'
        name='system.backpack.max'
        value='{{system.backpack.max}}'
        data-dtype='Number'
        min='0'
        class='status-next'
        readonly
      />
    </div>
    {{#if (gte backpackSpacesOccupied system.backpack.max)}}
      <div class='backpack-warning'>
        <i class="fas fa-exclamation-triangle"></i>
        {{localize 'CARDIGAN.BackpackFull'}}
      </div>
    {{/if}}
  </div>

  {{! Checkbox to control weapons table visibility }}
  <div class='form-group'>
    <label>
      <input
        type="checkbox"
        name="system.details.showWeaponsTable"
        {{#if system.details.showWeaponsTable}}checked{{/if}}
        data-dtype="Boolean"
      />
      {{localize "CARDIGAN.ShowWeapons"}}
    </label>
  </div>

  {{#if system.details.showWeaponsTable}}
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-formula'>{{localize 'CARDIGAN.Hand'}}</div>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-attack'></div>
      <div class='item-reload'>
        {{#if hasRangedWeapons}}
          {{localize 'CARDIGAN.ReloadButton'}}
        {{/if}}
      </div>
      <div class='item-ammunition'>
        {{#if hasRangedWeapons}}
          {{localize 'CARDIGAN.Ammunition'}}
        {{/if}}
      </div>
      <div class='item-durability'>
        {{#if hasNonUnarmedWeapons}}
          {{localize 'CARDIGAN.Durability'}}
        {{/if}}
      </div>
      <div class='item-unequip'>
        {{#if hasNonUnarmedWeapons}}
          {{localize 'CARDIGAN.Unequip'}}
        {{/if}}
      </div>
      <div class='item-controls'>
    </li>
    {{#each armas as |item id|}}
      <li
        class='item collapsible collapsed'
        data-item-id='{{item._id}}'
        data-uuid='{{item.uuid}}'
        data-drag='true'
        data-document-class='Item'
      >
        {{!-- Item Row Summary --}}
        <div class="item-row flexrow">
        <div class='item-formula item-prop'>
          {{#if item.system.rightHand}}
            {{#if item.system.leftHand}}
              <span class='hand-both'>P+S</span>
            {{else}}
              <span class='hand-primary'>P</span>
            {{/if}}
          {{else if item.system.leftHand}}
            <span class='hand-secondary'>S</span>
          {{else}}
            <span class='hand-none'>-</span>
          {{/if}}
        </div>
        <div class='item-name {{#if (eq item.system.durability.current 0)}}item-name-broken{{/if}}'>
          <div class='item-image'>
            <a 
              class='rollable weapon-image-click' 
              data-roll-type='item' 
              data-action='weaponToChat'
              data-item-id='{{item._id}}'
              title='Clique para mostrar informações no chat'
            >
              <img
                src='{{item.img}}'
                title='{{item.name}}'
                width='24'
                height='24'
              />
            </a>
          </div>
          <div 
            class="weapon-name-hover"
            data-item-id="{{item._id}}"
            data-action="toggleExpand"
          >
            {{item.name}}
          </div>
        </div>
        <div class='item-attack'>
          {{#if (or item.system.rightHand item.system.leftHand)}}
            {{#if @root.editable}}
              <a
                class='item-control attack-weapon {{#if (eq item.system.durability.current 0)}}disabled{{/if}}'
                title='{{#if (eq item.system.durability.current 0)}}Arma quebrada - não pode atacar{{else}}Atacar com {{item.name}}{{/if}}'
                data-action='attackWithWeapon'
                data-item-id='{{item._id}}'
                {{#if (eq item.system.durability.current 0)}}disabled{{/if}}
              >
                <i class='fas fa-crosshairs'></i>
              </a>

            {{/if}}
          {{/if}}
        </div>
        <div class='item-reload'>
          {{#unless item.system.isUnarmed}}
            {{#if (or item.system.ranged item.system.isFirearm)}}
              {{#if @root.editable}}
                <a
                  class='item-control manage-ammunition'
                  title='Gerenciar Munição'
                  data-action='manageAmmunition'
                  data-item-id='{{item._id}}'
                >
                  <i class='fas fa-redo'></i>
                </a>
              {{else}}
                <i class='fas fa-redo reload-icon-readonly' title='Reload'></i>
              {{/if}}
            {{/if}}
          {{/unless}}
        </div>
        <div class='item-ammunition'>
          {{#unless item.system.isUnarmed}}
            {{#if (or item.system.ranged item.system.isFirearm)}}
              {{#if item.system.isFirearm}}
                <span class='ammunition-firearm ammunition-display' data-weapon-id='{{item._id}}'>{{item.system.loadedAmmo}}/{{item.system.magazine}}</span>
              {{else}}
                <span class='ammunition-ranged ammunition-display' data-weapon-id='{{item._id}}'>{{item.system.loadedAmmo}}</span>
              {{/if}}
            {{/if}}
          {{/unless}}
        </div>
        <div class='item-durability'>
          {{#unless item.system.isUnarmed}}
            {{#if @root.editable}}
              <input
                type='number'
                class='durability-input'
                name='items.{{item._id}}.system.durability.current'
                value='{{item.system.durability.current}}'
                min='0'
                max='{{item.system.durability.max}}'
                data-dtype='Number'
                title='Durabilidade atual: {{item.system.durability.current}}/{{item.system.durability.max}}'
              />
            {{else}}
              <span title='Durabilidade atual: {{item.system.durability.current}}/{{item.system.durability.max}}'>
                {{item.system.durability.current}}
              </span>
            {{/if}}
          {{/unless}}
        </div>
        <div class='item-unequip'>
          {{#unless item.system.isUnarmed}}
            {{#if @root.editable}}
              <a
                class='item-control unequip-weapon unequip-button'
                title='{{localize "CARDIGAN.UnequipWeapon"}}'
                data-action='unequipWeapon'
                data-item-id='{{item._id}}'
              >
                <i class='fas fa-times-circle'></i>
              </a>
            {{/if}}
          {{/unless}}
        </div>
        <div class='item-controls'>
          {{#unless item.system.isUnarmed}}
            {{#if @root.editable}}
              {{!-- Context Menu Button (Three Dots) --}}
              <button type="button" class="unbutton item-control always-interactive" data-context-menu
                       >
                <i class="fa-solid fa-ellipsis-vertical" inert></i>
              </button>
            {{/if}}
          {{/unless}}
        </div>
        </div>
        
        {{!-- Expandable Description --}}
        <div class="item-description">
          <div class="wrapper">
            {{!-- Expanded content will be loaded here dynamically --}}
          </div>
        </div>
      </li>
    {{/each}}
  </ol>
  {{/if}}

  {{! Spacer between weapons and backpack }}
  <div class="section-divider"></div>

  {{! Armor Table - Equipped Armors }}
  <ol class='items-list'>
    <li class='item flexrow items-header'>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-armor-type'>{{localize 'CARDIGAN.ArmorTypeLabel'}}</div>
      <div class='item-protection'>{{localize 'CARDIGAN.Protection'}}</div>
      <div class='item-durability'>{{localize 'CARDIGAN.Durability'}}</div>
      <div class='item-unequip'>{{localize 'CARDIGAN.Unequip'}}</div>
      <div class='item-controls'></div>
    </li>
    {{#each armaduras as |item id|}}
      <li
        class='item collapsible collapsed'
        data-item-id='{{item._id}}'
        data-uuid='{{item.uuid}}'
        data-drag='true'
        data-document-class='Item'
      >
        {{!-- Item Row Summary --}}
        <div class="item-row flexrow">
        <div class='item-name {{#if (eq item.system.durability.current 0)}}item-name-broken{{/if}}'>
          <div class='item-image'>
            <img
              src='{{item.img}}'
              title='{{item.name}}'
              width='24'
              height='24'
            />
          </div>
          <div 
            class="armor-name-hover"
            
            
            data-item-id="{{item._id}}"
            data-action="toggleExpand"
          >
            {{item.name}}
          </div>
        </div>
        <div class='item-armor-type'>
          {{localize (concat "CARDIGAN.ArmorType." (capitalize item.system.armorType))}}
        </div>
        <div class='item-protection'>
          {{item.system.protecao}}
        </div>
        <div class='item-durability'>
          {{#if @root.editable}}
            <input
              type='number'
              class='durability-input'
              name='items.{{item._id}}.system.durability.current'
              value='{{item.system.durability.current}}'
              min='0'
              max='{{item.system.durability.max}}'
              data-dtype='Number'
              title='Durabilidade atual: {{item.system.durability.current}}/{{item.system.durability.max}}'
            />
          {{else}}
            <span title='Durabilidade atual: {{item.system.durability.current}}/{{item.system.durability.max}}'>
              {{item.system.durability.current}}
            </span>
          {{/if}}
        </div>
        <div class='item-unequip'>
          {{#if @root.editable}}
            <button
              class='item-control unequip-armor-btn'
              title='{{localize "CARDIGAN.UnequipArmor"}}'
              data-action='unequipArmor'
              data-item-id='{{item._id}}'
            >
              <i class='fas fa-shield-slash'></i>
            </button>
          {{/if}}
        </div>
        <div class='item-controls'>
          {{#if @root.editable}}
            {{!-- Context Menu Button (Three Dots) for Armor Table --}}
            <a
              class='item-control item-options'
              title='{{localize "CARDIGAN.ItemOptions"}}'
              data-context-menu
              data-item-id='{{item._id}}'
            >
              <i class='fas fa-ellipsis-v'></i>
            </a>
          {{/if}}
        </div>
        </div>
        
        {{!-- Expandable Description --}}
        <div class="item-description">
          <div class="wrapper">
            {{!-- Expanded content will be loaded here dynamically --}}
          </div>
        </div>
      </li>
    {{/each}}
  </ol>





  {{#if system.details.showBackpackContainer}}
  <div class="backpack-container">
    {{! Profession Filter Sidebar }}
    <div class="profession-filters">
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="all" id="filter-all" {{#if (eq professionFilter "all")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-all" class="filter-emoji">📦</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="alchemy" id="filter-alchemy" {{#if (eq professionFilter "alchemy")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-alchemy" class="filter-emoji">⚗️</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="blacksmithing" id="filter-blacksmithing" {{#if (eq professionFilter "blacksmithing")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-blacksmithing" class="filter-emoji">🔨</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="carpentry" id="filter-carpentry" {{#if (eq professionFilter "carpentry")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-carpentry" class="filter-emoji">🪚</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="culinary" id="filter-culinary" {{#if (eq professionFilter "culinary")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-culinary" class="filter-emoji">🍳</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="tailoring" id="filter-tailoring" {{#if (eq professionFilter "tailoring")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-tailoring" class="filter-emoji">🧵</label>
      </div>
      <div class="filter-option"  >
        <input type="radio" name="profession-filter" value="tecnomagic" id="filter-tecnomagic" {{#if (eq professionFilter "tecnomagic")}}checked{{/if}} data-action="filterProfession">
        <label for="filter-tecnomagic" class="filter-emoji">⚡️</label>
      </div>
    </div>
    
    {{! Backpack Table }}
    <ol class='items-list backpack-table'>
      <li class='item flexrow items-header'>
        <div class='item-name'>{{localize 'Name'}}</div>
        <div class='item-quantity'>{{localize 'CARDIGAN.Common.Quantity'}}</div>
        <div class='item-weight'>{{localize 'CARDIGAN.Common.Weight'}}</div>
        <div class='item-equip'></div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <button
              type='button'
              class='item-control item-create-with-selection'
              title='{{localize "DOCUMENT.Create" type="Item"}}'
              data-action='createDocWithSelection'
            >
              <i class='fas fa-plus'></i>
              {{localize 'CARDIGAN.AddBackpack'}}
            </button>
          {{/if}}
        </div>
      </li>
    {{#each backpack as |item id|}}
      <li
        class='item flexrow'
        data-item-id='{{item._id}}'
        data-uuid='{{item.uuid}}'
        data-drag='true'
        data-document-class='Item'
      >
        <div class='item-name'>
          <div class='item-image'>
            <a class='rollable' data-roll-type='item' data-action='roll'>
              <img
                src='{{item.img}}'
                title='{{item.name}}'
                width='24'
                height='24'
              />
            </a>
          </div>
          <div>{{item.name}}</div>
        </div>
        <div class='item-quantity'>
          {{#if @root.editable}}
            {{#if (or (eq item.type "item-comum") (eq item.type "item-municao") (eq item.type "item-consumivel") (eq item.type "item-ingredient"))}}
              <input
                type='number'
                name='items.{{item._id}}.system.quantity'
                value='{{item.system.quantity}}'
                min='0'
                data-dtype='Number'
                style='width: 60px; text-align: center;'
                title='Quantidade: {{item.system.quantity}}'
              />
            {{else}}
              <span title='Quantidade: {{item.system.quantity}}'>
                {{item.system.quantity}}
              </span>
            {{/if}}
          {{else}}
            <span title='Quantidade: {{item.system.quantity}}'>
              {{item.system.quantity}}
            </span>
          {{/if}}
                </div>
        <div class='item-weight'>{{abbreviateWeight item.system.weight}}</div>
        <div class='item-equip'>
          {{#if @root.editable}}
            {{#if (eq item.type "arma")}}
              {{#if (or item.system.rightHand item.system.leftHand)}}
                <i class='fas fa-shield-alt' style='color: #4caf50; font-size: 16px;' title='{{localize "CARDIGAN.Equipped"}}'></i>
              {{else}}
                <a
                  class='item-control equip-weapon'
                  title='{{localize "CARDIGAN.EquipWeapon"}}'
                  data-action='equipWeapon'
                  data-item-id='{{item._id}}'
                  style='color: #4caf50; font-size: 16px;'
                >
                  <i class='fas fa-shield-alt'></i>
                </a>
              {{/if}}
            {{else if (eq item.type "armadura")}}
              {{#if item.system.equipped}}
                <i class='fas fa-shield' style='color: #2196f3; font-size: 16px;' title='{{localize "CARDIGAN.Equipped"}}'></i>
              {{else}}
                <a
                  class='item-control equip-armor'
                  title='{{localize "CARDIGAN.EquipArmor"}}'
                  data-action='equipArmor'
                  data-item-id='{{item._id}}'
                  style='color: #2196f3; font-size: 16px;'
                >
                  <i class='fas fa-shield'></i>
                </a>
              {{/if}}
            {{else if (eq item.type "item-consumivel")}}
              <a
                class='item-control consume-item'
                title='{{localize "CARDIGAN.UseConsumable"}}'
                data-action='consumeItem'
                data-item-id='{{item._id}}'
                style='color: #ff9800; font-size: 16px; cursor: pointer;'
              >
                <i class='fas fa-flask'></i>
              </a>
            {{/if}}
          {{else}}
            {{#if (eq item.type "arma")}}
              {{#if (or item.system.rightHand item.system.leftHand)}}
                <i class='fas fa-shield-alt' style='color: #4caf50; font-size: 16px;' title='{{localize "CARDIGAN.Equipped"}}'></i>
              {{/if}}
            {{else if (eq item.type "armadura")}}
              {{#if item.system.equipped}}
                <i class='fas fa-shield' style='color: #2196f3; font-size: 16px;' title='{{localize "CARDIGAN.Equipped"}}'></i>
              {{/if}}
            {{else if (eq item.type "item-consumivel")}}
              <i class='fas fa-flask' style='color: #ff9800; font-size: 16px;' title='{{localize "CARDIGAN.Consumable"}}'></i>
            {{/if}}
          {{/if}}
        </div>
        <div class='item-controls'>
          {{#if @root.editable}}
            {{!-- Context Menu Button (Three Dots) for Backpack Table --}}
            <button type="button" class="unbutton item-control always-interactive" data-context-menu
                      data-item-id="{{item._id}}">
              <i class="fa-solid fa-ellipsis-vertical" inert></i>
            </button>
          {{/if}}
        </div>
      </li>
    {{/each}}
    </ol>
  </div>
  {{/if}}
</section>

