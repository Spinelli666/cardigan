<section class='tab equipment {{tab.cssClass}}' data-group='primary' data-tab='equipment'>
  
  {{! Money & Business Banner }}
  <div class="money-business-banner">
    <div class="money-inner">
      <img src='systems/cardigan/assets/images/decorative/icons/icon-coins.svg' alt='Moedas' class='money-coin-icon' />
      <div class="money-field-container">
        <input
          type='number'
          name='system.money'
          value='{{system.money}}'
          data-dtype='Number'
          min='0'
          class='money-field'
          data-tooltip='CARDIGAN.Tooltip.Money'
          data-tooltip-class='cardigan-tooltip'
          {{#unless @root.isGM}}disabled{{/unless}}
        />
      </div>
    </div>
    {{#unless (eq actor.type "npc")}}
    <div class="negotiation-container">
      <button type='button' class='negotiate-button' data-action='initiateTrade'
        data-tooltip='CARDIGAN.Tooltip.Negotiate' data-tooltip-class='cardigan-tooltip'>
        <img src='systems/cardigan/assets/images/decorative/icons/icon-negotiation.svg' alt='Negociar' class='negotiate-icon' />
      </button>
    </div>
    {{/unless}}
  </div>

  {{! Inventory Banner }}
  <div class="inventory-banner">
    <div class="backpack-toggle">
      <input
        type="checkbox"
        name="system.details.showBackpackContainer"
        {{#if system.details.showBackpackContainer}}checked{{/if}}
        data-dtype="Boolean"
        style="display: none;"
      />
      <img
        src="systems/cardigan/assets/images/decorative/backpack.svg"
        alt="Toggle Backpack"
        class="backpack-toggle-icon"
        data-action="toggleBackpackContainer"
        data-tooltip='CARDIGAN.Tooltip.Backpack'
        data-tooltip-class='cardigan-tooltip'
      />
    </div>
    <div class='status-display {{#if (gte backpackSpacesOccupied system.backpack.max)}}backpack-full{{/if}}'
      data-tooltip='CARDIGAN.Tooltip.Weight'
      data-tooltip-class='cardigan-tooltip'>
      <input
        type='number'
        name='system.backpack.current'
        value='{{backpackSpacesOccupied}}'
        data-dtype='Number'
        min='0'
        class='status-current {{#if (gte backpackSpacesOccupied system.backpack.max)}}backpack-full-text{{/if}}'
        readonly
      />
      <img
        src='systems/cardigan/assets/images/decorative/field-divider.svg'
        alt='/'
        class='status-separator-icon'
      />
      <input
        type='number'
        name='system.backpack.max'
        value='{{system.backpack.max}}'
        data-dtype='Number'
        min='0'
        class='status-next'
        readonly
      />
    </div>
    {{#if (gte backpackSpacesOccupied system.backpack.max)}}
      <div class='backpack-warning'>
        <i class="fas fa-exclamation-triangle"></i>
        {{localize 'CARDIGAN.BackpackFull'}}
      </div>
    {{/if}}
    {{#if system.details.showBackpackContainer}}
    <div class="backpack-section">
    {{#if @root.editable}}
    <div class="backpack-actions">
      <div class="backpack-filter-search-wrapper">
        <div class="backpack-filter-search-group">
          <div class="filter-cointainer" data-tooltip='Filtrar profissões' data-tooltip-class='cardigan-tooltip'>
            <label class="filter-button-visual">
              <input type="checkbox" class="filter-button" aria-label="Filtrar profissões" {{#if isProfessionFilterOpen}}checked{{/if}} />
              <img
                src="systems/cardigan/assets/images/decorative/icons/icon-filter.svg"
                alt="Filtrar profissões"
                class="filter-icon"
              />
            </label>
          </div>
          <div class="search-container" data-tooltip='Buscar no inventário' data-tooltip-class='cardigan-tooltip'>
            <label class="search-button-visual">
              <input
                type="checkbox"
                class="search-button"
                aria-label="Buscar no inventário"
                {{#if isBackpackSearchOpen}}checked{{/if}}
              />
              <img
                src="systems/cardigan/assets/images/decorative/icons/icon-search.svg"
                alt="Buscar no inventário"
                class="search-icon"
              />
            </label>
          </div>
        </div>
      </div>
      <div class="backpack-search-panel">
        <input
          type="text"
          class="backpack-search-field"
          value="{{backpackSearch}}"
          placeholder="Buscar no inventário..."
          aria-label="Buscar no inventário"
          autocomplete="off"
        />
      </div>
      <div class="add-item-button-container" data-tooltip='CARDIGAN.AddBackpack' data-tooltip-class='cardigan-tooltip'>
        <img
          src="systems/cardigan/assets/images/decorative/icons/icon-add-effects.svg"
          alt="{{localize 'CARDIGAN.AddBackpack'}}"
          class="add-item-icon"
          data-action='createDocWithSelection'
        />
      </div>
    </div>
    {{/if}}
    <div class="backpack-container">
      {{! Profession Filter Sidebar }}
      <div class="profession-filters">
        <div class="filter-option" data-tooltip='Gerais' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="all" id="filter-all" {{#if (eq professionFilter "all")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-all" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-profession.webp" alt="Todas as profissões" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Culinária' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="culinary" id="filter-culinary" {{#if (eq professionFilter "culinary")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-culinary" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-culinary.svg" alt="Culinária" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Alquimia' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="alchemy" id="filter-alchemy" {{#if (eq professionFilter "alchemy")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-alchemy" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-alchemy.svg" alt="Alquimia" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Costura' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="tailoring" id="filter-tailoring" {{#if (eq professionFilter "tailoring")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-tailoring" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-tailoring.svg" alt="Alfaiataria" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Ferraria' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="blacksmithing" id="filter-blacksmithing" {{#if (eq professionFilter "blacksmithing")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-blacksmithing" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-blacksmithing.svg" alt="Ferraria" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Tecnomagia' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="tecnomagic" id="filter-tecnomagic" {{#if (eq professionFilter "tecnomagic")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-tecnomagic" class="filter-emoji">
            <img src="systems/cardigan/assets/images/profession/icon-technomagic.svg" alt="Tecnomagia" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Armas' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="weapons" id="filter-weapons" {{#if (eq professionFilter "weapons")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-weapons" class="filter-emoji">
            <img src="systems/cardigan/assets/images/weapons/sword.webp" alt="Armas" />
          </label>
        </div>
        <div class="filter-option" data-tooltip='Armaduras' data-tooltip-class='cardigan-tooltip'>
          <input type="radio" name="profession-filter" value="armors" id="filter-armors" {{#if (eq professionFilter "armors")}}checked{{/if}} data-action="filterProfession">
          <label for="filter-armors" class="filter-emoji">
            <img src="systems/cardigan/assets/images/weapons/shield-weapon.webp" alt="Armaduras" />
          </label>
        </div>
      </div>
      
      {{! Backpack Table }}
      <ol class='items-list backpack-table'>
        <li class='item flexrow items-header'>
          <div class='item-name'>{{localize 'Name'}}</div>
          <div class='item-reload-ammunition-wrapper'>
            <div class='item-reload'>{{localize 'CARDIGAN.ReloadButton'}}</div>
            <div class='item-ammunition'>{{localize 'CARDIGAN.Ammunition'}}</div>
          </div>
          <div class='item-information'>
          </div>
          <div class='item-durability'>
            <img
              src='systems/cardigan/assets/images/decorative/icons/icon-durability.svg'
              alt='Durabilidade'
              class='durability-icon-header'
              width='24'
              height='24'
            />
            {{localize 'CARDIGAN.Durability'}}
          </div>
          <div class='item-quantity'>{{localize 'CARDIGAN.Common.Quantity'}}</div>
          <div class='item-equip'></div>
          <div class='item-controls'></div>
        </li>
      {{#each backpack as |item id|}}
        <li
          class='item flexrow {{#if (or (eq item.type "item-comum") (eq item.type "item-municao") (eq item.type "item-ingredient") (eq item.type "backpack"))}}backpack-row-generic{{/if}} {{#if (eq item.type "item-consumivel")}}backpack-row-consumable{{/if}} {{#if (eq item.type "arma")}}backpack-row-weapon {{#unless (or item.system.ranged item.system.isFirearm)}}backpack-row-weapon-no-reload{{/unless}} {{#unless item.system.protection.enabled}}backpack-row-weapon-no-information{{/unless}} {{#if (and item.system.protection.enabled (not (or item.system.ranged item.system.isFirearm)))}}backpack-row-weapon-protection-no-reload{{/if}}{{/if}} {{#if (eq item.type "armadura")}}backpack-row-armor{{/if}} {{#if (and (or (eq item.type "arma") (eq item.type "armadura")) (eq item.system.durability.current 0))}}durability-broken{{/if}}'
          data-item-id='{{item._id}}'
          data-uuid='{{item.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          <div class='item-image'>
            <a class='rollable' data-roll-type='item' data-action='roll'>
              <img
                src='{{item.img}}'
                title='{{item.name}}'
                width='24'
                height='24'
              />
            </a>
          </div>
          <div class='item-name-group'>
            <div class='item-name {{#if (and (or (eq item.type "arma") (eq item.type "armadura")) (eq item.system.durability.current 0))}}item-name-broken{{/if}}'>
              <div>{{item.name}}</div>
            </div>
            {{#if (eq item.type "armadura")}}
              <div class='item-single-heavy'>
                {{#if item.system.single}}
                  <img
                    src='systems/cardigan/assets/images/decorative/icons/icon-single-equipped.svg'
                    alt='{{localize "CARDIGAN.Single"}}'
                    class='single-equipped-icon'
                    width='18'
                    height='18'
                    data-tooltip='Único'
                    data-tooltip-class='cardigan-tooltip'
                  />
                {{/if}}
                {{#if (eq item.system.weight "pesado")}}
                  <img
                    src='systems/cardigan/assets/images/decorative/icons/icon-heavy-item.svg'
                    alt='{{localize "CARDIGAN.Heavy"}}'
                    class='heavy-item-icon'
                    width='15'
                    height='15'
                    data-tooltip='Pesada'
                    data-tooltip-class='cardigan-tooltip'
                  />
                {{/if}}
              </div>
            {{/if}}
          </div>
          {{> "systems/cardigan/templates/actor/partials/weapon-reload-ammo.hbs" item=item}}
          <div class='item-information'>
            {{#if (and (eq item.type "arma") item.system.protection.enabled)}}
              <div class='protection info-badge'>
                <img
                  src='systems/cardigan/assets/images/decorative/icons/icon-armor.svg'
                  alt='{{localize "CARDIGAN.Protection"}}'
                  class='information-icon'
                  width='20'
                  height='20'
                />
                <div class='bonus-display'>
                  <span class='bonus-value'>+{{item.system.protection.value}}</span>
                </div>
              </div>
            {{/if}}

            {{#if (eq item.type "armadura")}}
              {{> "systems/cardigan/templates/actor/partials/armor-info-badges.hbs" item=item}}
            {{/if}}
          </div>
          <div class='item-durability {{#if (and (or (eq item.type "arma") (eq item.type "armadura")) (eq item.system.durability.current 0))}}durability-broken{{/if}}'>
            {{#if (or (eq item.type "arma") (eq item.type "armadura"))}}
              {{> "systems/cardigan/templates/actor/partials/durability-display.hbs" item=item}}
            {{/if}}
          </div>
          <div class='item-quantity'>
            {{#if @root.editable}}
              {{#if (or (eq item.type "item-comum") (eq item.type "item-municao") (eq item.type "item-consumivel") (eq item.type "item-ingredient") (eq item.type "arma") (eq item.type "armadura"))}}
                <img
                  src='systems/cardigan/assets/images/decorative/icons/icon-delete.svg'
                  alt='Delete'
                  class='quantity-delete-icon'
                  width='10'
                  height='10'
                />
                <input
                  type='number'
                  name='items.{{item._id}}.system.quantity'
                  value='{{item.system.quantity}}'
                  min='0'
                  data-dtype='Number'
                  style='text-align: center;'
                  data-tooltip='Quantidade'
                  data-tooltip-class='cardigan-tooltip'
                />
              {{else}}
                <span data-tooltip='Quantidade' data-tooltip-class='cardigan-tooltip'>
                  {{item.system.quantity}}
                </span>
              {{/if}}
            {{else}}
              <span title='Quantidade: {{item.system.quantity}}'>
                {{item.system.quantity}}
              </span>
            {{/if}}
          </div>
          <div class='item-equip'>
            {{#if @root.editable}}
              {{#if (eq item.type "arma")}}
                {{#unless (or item.system.rightHand item.system.leftHand)}}
                  <a
                    class='item-control equip-weapon'
                    data-tooltip='CARDIGAN.Tooltip.Equip'
                    data-tooltip-class='cardigan-tooltip'
                    data-action='equipWeapon'
                    data-item-id='{{item._id}}'
                  >
                    <img
                      src='systems/cardigan/assets/images/decorative/icons/icon-equip.svg'
                      alt='{{localize "CARDIGAN.Tooltip.Equip"}}'
                      width='20'
                      height='20'
                    />
                  </a>
                {{/unless}}
              {{else if (eq item.type "armadura")}}
                {{#unless item.system.equipped}}
                  <a
                    class='item-control equip-armor'
                    data-tooltip='CARDIGAN.Tooltip.Equip'
                    data-tooltip-class='cardigan-tooltip'
                    data-action='equipArmor'
                    data-item-id='{{item._id}}'
                  >
                    <img
                      src='systems/cardigan/assets/images/decorative/icons/icon-equip.svg'
                      alt='{{localize "CARDIGAN.Tooltip.Equip"}}'
                      width='20'
                      height='20'
                    />
                  </a>
                {{/unless}}
              {{else if (eq item.type "item-consumivel")}}
                <a
                  class='item-control consume-item'
                  data-tooltip='CARDIGAN.Tooltip.Use'
                  data-tooltip-class='cardigan-tooltip'
                  data-action='consumeItem'
                  data-item-id='{{item._id}}'
                >
                  <img
                    src='systems/cardigan/assets/images/decorative/icons/icon-equip.svg'
                    alt='{{localize "CARDIGAN.Tooltip.Use"}}'
                    width='20'
                    height='20'
                  />
                </a>
              {{/if}}
            {{/if}}
          </div>
          <div class='item-controls'>
            {{#if @root.editable}}
              {{!-- Context Menu Button (Three Dots) for Backpack Table --}}
              <button type="button" class="unbutton item-control always-interactive" data-context-menu
                        data-item-id="{{item._id}}">
                <i class="fa-solid fa-ellipsis-vertical" inert></i>
              </button>
            {{/if}}
          </div>
        </li>
      {{/each}}
      </ol>
    </div>
    </div>
    {{/if}}
  </div>
  <div class="equipament-banner">
    <div class="equipament-toggle">
      <input
        type="checkbox"
        name="system.details.showWeaponsTable"
        {{#if system.details.showWeaponsTable}}checked{{/if}}
        data-dtype="Boolean"
        style="display: none;"
      />
      <img
        src="systems/cardigan/assets/images/decorative/equipament.svg"
        alt="Toggle Equipment"
        class="equipament-toggle-icon"
        data-action="toggleWeaponsTable"
        data-tooltip='CARDIGAN.ShowWeapons'
        data-tooltip-class='cardigan-tooltip'
      />
    </div>

  {{#if system.details.showWeaponsTable}}
  <div class="equipament-container">
  <ol class='items-list equipament-table'>
    <li class='item flexrow items-header'>
      <div class='item-formula'>{{localize 'CARDIGAN.Hand'}}</div>
      <div class='item-name'>{{localize 'Name'}}</div>
      <div class='item-attack'></div>
      <div class='item-reload-ammunition-wrapper'>
        <div class='item-reload'>
          {{#if hasRangedWeapons}}
            {{localize 'CARDIGAN.ReloadButton'}}
          {{/if}}
        </div>
        <div class='item-ammunition'>
          {{#if hasRangedWeapons}}
            {{localize 'CARDIGAN.Ammunition'}}
          {{/if}}
        </div>
      </div>
      <div class='item-information'>
      </div>
      <div class='item-durability'>
        <img
          src='systems/cardigan/assets/images/decorative/icons/icon-durability.svg'
          alt='Durabilidade'
          class='durability-icon-header'
          width='24'
          height='24'
        />
        {{#if hasNonUnarmedWeapons}}
          {{localize 'CARDIGAN.Durability'}}
        {{/if}}
      </div>
      <div class='item-unequip'>
        {{#if hasNonUnarmedWeapons}}
          {{localize 'CARDIGAN.Tooltip.Unequip'}}
        {{/if}}
      </div>
      <div class='item-controls'>
    </li>
    {{#each armas as |item id|}}
      <li
        class='item collapsible collapsed {{#if (eq item.system.durability.current 0)}}durability-broken{{/if}}'
        data-item-id='{{item._id}}'
        data-uuid='{{item.uuid}}'
        data-drag='true'
        data-document-class='Item'
      >
        {{!-- Item Row Summary --}}
        <div class='item-wrapper flexrow {{#if item.system.isUnarmed}}unarmed-wrapper{{/if}}'>
          <div class='item-formula item-prop'>
            {{#if item.system.rightHand}}
              <img 
                src='/systems/cardigan/assets/images/weapons/right-hand.webp' 
                alt='Mão Direita (P)' 
                class='hand-icon right-hand-icon'
                title='Mão Primária'
              />
            {{else if item.system.leftHand}}
              <img 
                src='/systems/cardigan/assets/images/weapons/left-hand.webp' 
                alt='Mão Esquerda (S)' 
                class='hand-icon left-hand-icon'
                title='Mão Secundária'
              />
            {{/if}}
          </div>
          <div class="item-row flexrow {{#if item.system.isUnarmed}}unarmed-row{{/if}}">
        <div class='item-image'>
          <a
            class='weapon-image-attack {{#if (eq item.system.durability.current 0)}}disabled{{/if}}'
            {{#unless (eq item.system.durability.current 0)}}data-action='attackWithWeapon'{{/unless}}
            data-item-id='{{item._id}}'
            title='{{#if (eq item.system.durability.current 0)}}Arma quebrada - não pode atacar{{else}}Atacar com {{item.name}}{{/if}}'
          >
            <img
              class='weapon-base-icon'
              src='{{item.img}}'
              title='{{item.name}}'
              width='24'
              height='24'
            />
            <img
              class='weapon-d20-icon'
              src='systems/cardigan/assets/images/decorative/icons/icon-d20.svg'
              alt='Atacar'
              width='24'
              height='24'
            />
          </a>
        </div>
        <div class='item-name {{#if (eq item.system.durability.current 0)}}item-name-broken{{/if}}'>
          <div 
            class="weapon-name-hover"
            data-item-id="{{item._id}}"
            data-action="toggleExpand"
          >
            {{item.name}}
          </div>
        </div>
        {{> "systems/cardigan/templates/actor/partials/weapon-reload-ammo.hbs" item=item}}
        <div class='item-information'>
        </div>
        <div class='item-durability {{#if item.system.isUnarmed}}unarmed-durability-hidden{{/if}} {{#if (eq item.system.durability.current 0)}}durability-broken{{/if}}'>
          {{#unless item.system.isUnarmed}}
            {{> "systems/cardigan/templates/actor/partials/durability-display.hbs" item=item}}
          {{/unless}}
        </div>
        <div class='item-unequip'>
          {{#unless item.system.isUnarmed}}
            {{#if @root.editable}}
              <a
                class='item-control unequip-weapon unequip-button'
                data-tooltip='CARDIGAN.Tooltip.Unequip'
                data-tooltip-class='cardigan-tooltip'
                data-action='unequipWeapon'
                data-item-id='{{item._id}}'
              >
                <img
                  src='systems/cardigan/assets/images/decorative/icons/icon-equip.svg'
                  alt='{{localize "CARDIGAN.Tooltip.Unequip"}}'
                  width='20'
                  height='20'
                />
              </a>
            {{/if}}
          {{/unless}}
        </div>
        <div class='item-controls'>
          {{#unless item.system.isUnarmed}}
            {{#if @root.editable}}
              {{!-- Context Menu Button (Three Dots) --}}
              <button type="button" class="unbutton item-control always-interactive" data-context-menu
                       >
                <i class="fa-solid fa-ellipsis-vertical" inert></i>
              </button>
            {{/if}}
          {{/unless}}
        </div>
        </div>
        </div>
        
        {{!-- Expandable Description --}}
        <div class="item-description">
          <div class="wrapper">
            {{!-- Expanded content will be loaded here dynamically --}}
          </div>
        </div>
      </li>
    {{/each}}
  </ol>
  </div>
  {{/if}}

  {{#if (and system.details.showWeaponsTable hasHeaderArmorEquipped)}}
  <div class="armor-equipament-container">
    {{> "systems/cardigan/templates/actor/partials/armor-section-container.hbs"
      guard=hasHeadArmorEquipped
      containerClass="head-container"
      titleRowClass="head-title-row"
      imgSrc="systems/cardigan/assets/images/armor/head.webp"
      imgAlt="Cabeça"
      imgClass="head-image"
      label="CABEÇA"
      tableClass="head-armor-table"
      armorType="head"
      itemClass="head-armor-item"
    }}

    {{> "systems/cardigan/templates/actor/partials/armor-section-container.hbs"
      guard=hasTorsoArmorEquipped
      containerClass="torso-container"
      titleRowClass="torso-title-row"
      imgSrc="systems/cardigan/assets/images/armor/chest.webp"
      imgAlt="Torso"
      imgClass="torso-image"
      label="TORSO"
      tableClass="torso-armor-table"
      armorType="torso"
      itemClass="torso-armor-item"
    }}

    {{> "systems/cardigan/templates/actor/partials/armor-section-container.hbs"
      guard=hasArmsArmorEquipped
      containerClass="arms-container"
      titleRowClass="arms-title-row"
      imgSrc="systems/cardigan/assets/images/armor/arms.webp"
      imgAlt="Braços"
      imgClass="arms-image"
      label="BRAÇOS"
      tableClass="arms-armor-table"
      armorType="arms"
      itemClass="arms-armor-item"
    }}

    {{> "systems/cardigan/templates/actor/partials/armor-section-container.hbs"
      guard=hasLegsArmorEquipped
      containerClass="legs-container"
