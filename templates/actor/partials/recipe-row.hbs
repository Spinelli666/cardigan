{{!-- recipe-row.hbs: <li> completo de uma recipe row --}}
{{!-- Parâmetros: recipe, recipeType (string), craftIconColor (string), isCookable (boolean) --}}
<li
  class='item collapsible collapsed'
  data-item-id='{{recipe._id}}'
  data-uuid='{{recipe.uuid}}'
  data-drag='true'
  data-document-class='Item'
>
  {{!-- Item Row Summary --}}
  <div class="item-row flexrow">
    <div class='item-name'>
      <div class='item-image'>
        {{#if isCookable}}
          <a class='rollable' data-action='cookRecipe' data-recipe-id='{{recipe._id}}'>
            <img src='{{recipe.img}}' title='{{recipe.name}}' width='24' height='24'/>
          </a>
        {{else}}
          <img src='{{recipe.img}}' title='{{recipe.name}}' width='24' height='24'/>
        {{/if}}
      </div>
      <div
        class="recipe-name-hover"
        data-item-id="{{recipe._id}}"
        data-action="toggleExpand"
        style="cursor: pointer;"
      >
        {{recipe.name}}
      </div>
    </div>
    <div class='item-controls'>
      {{#if @root.editable}}
        <a class='item-control item-craft' title='{{localize "CARDIGAN.CraftItem"}}' data-action='craftFromRecipe' data-recipe-id='{{recipe._id}}' data-recipe-type='{{recipeType}}'>
          <i class='fas fa-hammer' style='color: {{craftIconColor}};'></i>
        </a>
        <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
          <i class='fas fa-edit'></i>
        </a>
        {{#unless (or skill.system.isLinkedSkill skill.system.enhancementLinkedSkill.isEnhancementLinked)}}
          <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
            <i class='fas fa-trash'></i>
          </a>
        {{/unless}}
      {{/if}}
    </div>
  </div>

  {{!-- Expandable Description --}}
  <div class="item-description">
    <div class="wrapper">
      {{!-- Expanded content will be loaded here dynamically --}}
    </div>
  </div>
</li>
