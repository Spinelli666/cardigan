{{! Sheet Header }}
<header class='sheet-header'>
  {{! Top Container - Holds left, center, right }}
  <div class='header-top-container'>
    {{! Left Aside - Four blocks }}
    <aside class='header-left'>
      <div class='bloco-1'></div>
      <div class='bloco-2'></div>
      <div class='bloco-3'></div>
      <div class='bloco-4'></div>
    </aside>

    {{! Center Div - Profile Image }}
    <div class='header-center'>
      <img
        class='profile-img'
        src='{{actor.img}}'
        data-edit='img'
        data-action='onEditImage'
        title='{{actor.name}}'
      />
    </div>

    {{! Right Aside }}
    <aside class='header-right'>
    </aside>
  </div>

  {{! Bottom Section - Character Name }}
  <section class='header-bottom-section'>
    <input
      name='name'
      type='text'
      value='{{actor.name}}'
      placeholder='Name'
    />
  </section>
</header>