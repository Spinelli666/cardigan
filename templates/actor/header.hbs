{{! Sheet Header }}
<header class='sheet-header'>
  <img
    class='profile-img'
    src='{{actor.img}}'
    data-edit='img'
    data-action='onEditImage'
    title='{{actor.name}}'
    height='100'
    width='100'
  />
  <div class='header-fields'>
    <div class='document-name'>
      <input
        name='name'
        type='text'
        value='{{actor.name}}'
        placeholder='Name'
      />
    </div>
    
    {{#unless (eq actor.type "npc")}}
    <div class='rest-buttons flexrow flex-center'>
      <button type='button' class='rest-button short-rest' data-action='shortRest' title='Short Rest (1d20 + 2×Vigor)'>
        <i class='fas fa-moon'></i> Short Rest
      </button>
      <button type='button' class='rest-button long-rest' data-action='longRest' title='Long Rest (2d20 + 3×Vigor)'>
        <i class='fas fa-bed'></i> Long Rest
      </button>
    </div>
    {{/unless}}
    {{! The grid classes are defined in scss/global/_grid.scss. To use,
      use both the "grid" and "grid-Ncol" class where "N" can be any number
      from 1 to 12 and will create that number of columns.  }}
    <div class='resources grid {{#if (eq actor.type "npc")}}grid-3col{{else}}grid-2col{{/if}}'>

      {{! "flex-group-center" is also defined in the _grid.scss file
        and it will add a small amount of padding, a border, and will
        center all of its child elements content and text. }}
      {{#if (eq actor.type 'npc')}}
        <div class='resource flex-group-center'>
          <label class='resource-label'>
            {{localize 'CARDIGAN.Actor.NPC.FIELDS.cr.label'}} / {{localize 'CARDIGAN.Actor.NPC.xp.label'}}
          </label>
          <div class='resource-content flexrow flex-center flex-between'>
            <input
              type='text'
              name='system.cr'
              value='{{system.cr}}'
              data-dtype='Number'
            />
            <span>/</span>
            <input
              type='text'
              disabled='true'
              name='system.xp'
              value='{{system.xp}}'
              data-dtype='Number'
            />
          </div>
        </div>
      {{/if}}

      {{#if (eq actor.type 'npc')}}
        <div class='resource flex-group-center'>
          <label class='resource-label'>
            {{localize 'CARDIGAN.Actor.NPC.FIELDS.cr.label'}} / {{localize 'CARDIGAN.Actor.NPC.xp.label'}}
          </label>
          <div class='resource-content flexrow flex-center flex-between'>
            <input
              type='text'
              name='system.cr'
              value='{{system.cr}}'
              data-dtype='Number'
            />
            <span>/</span>
            <input
              type='text'
              disabled='true'
              name='system.xp'
              value='{{system.xp}}'
              data-dtype='Number'
            />
          </div>
        </div>
      {{/if}}
    </div>
  </div>
</header>