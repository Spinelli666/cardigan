{{! Skills Tab with Profession Recipe Tables }}
<section class='tab skills {{tab.cssClass}}' data-group='primary' data-tab='skills'>
  
  {{! Container Classes }}
  <div class='container-teste'>
    <h3>Classes</h3>
    
    {{! Classes Row }}
    <div class='classes-row'>
      <div class='class-field'>
        <label>ANDARILHO</label>
        <input
          type='number'
          name='system.classes.wanderer'
          value='{{system.classes.wanderer}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>GUERREIRO</label>
        <input
          type='number'
          name='system.classes.warrior'
          value='{{system.classes.warrior}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>LADINO</label>
        <input
          type='number'
          name='system.classes.rogue'
          value='{{system.classes.rogue}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>FEITICEIRO</label>
        <input
          type='number'
          name='system.classes.sorcerer'
          value='{{system.classes.sorcerer}}'
          data-dtype='Number'
          min='0'
        />
      </div>
    </div>
  </div>

  {{! SKILL CLASS TABLE TOGGLES - Responsive layout }}
  <div class="skill-toggles-container">
    {{! Andarilho Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.WandererSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsWandererTable" {{checked system.details.showSkillsWandererTable}} data-dtype="Boolean" data-wanderer-skills-table-toggle />
      <i class="fas fa-hiking {{#if system.details.showSkillsWandererTable}}active{{/if}}" style="color: #8bc34a;"></i>
    </label>

    {{! Guerreiro Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.WarriorSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsWarriorTable" {{checked system.details.showSkillsWarriorTable}} data-dtype="Boolean" data-warrior-skills-table-toggle />
      <i class="fas fa-sword {{#if system.details.showSkillsWarriorTable}}active{{/if}}" style="color: #f44336;"></i>
    </label>

    {{! Ladino Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.RogueSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsRogueTable" {{checked system.details.showSkillsRogueTable}} data-dtype="Boolean" data-rogue-skills-table-toggle />
      <i class="fas fa-mask {{#if system.details.showSkillsRogueTable}}active{{/if}}" style="color: #9c27b0;"></i>
    </label>

    {{! Feiticeiro Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.SorcererSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsSorcererTable" {{checked system.details.showSkillsSorcererTable}} data-dtype="Boolean" data-sorcerer-skills-table-toggle />
      <i class="fas fa-magic {{#if system.details.showSkillsSorcererTable}}active{{/if}}" style="color: #2196f3;"></i>
    </label>

    {{! Raciais Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.RacialSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsRacialTable" {{checked system.details.showSkillsRacialTable}} data-dtype="Boolean" data-racial-skills-table-toggle />
      <i class="fas fa-users {{#if system.details.showSkillsRacialTable}}active{{/if}}" style="color: #ff9800;"></i>
    </label>

    {{! Únicas Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.UniqueSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsUniqueTable" {{checked system.details.showSkillsUniqueTable}} data-dtype="Boolean" data-unique-skills-table-toggle />
      <i class="fas fa-star {{#if system.details.showSkillsUniqueTable}}active{{/if}}" style="color: #ffc107;"></i>
    </label>
  </div>

  {{! SKILL CLASS TABLES - All skill tables by class }}
  
  {{! Andarilho Skills Table }}
  <div class="skill-table-container wanderer-skills-table-container {{#unless system.details.showSkillsWandererTable}}hidden{{/unless}}" data-wanderer-skills-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #8bc34a; text-align: center;">
      <i class="fas fa-hiking" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.WandererSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-type'>Type</div>
        <div class='item-enhancements'>Enhancements</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Andarilho Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Andarilho Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsWanderer as |skill id|}}
        {{> "systems/cardigan/templates/actor/partials/skill-row.hbs" skill=skill showEnhancements=true allowDelete=true}}
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-hiking" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #8bc34a;"></i>
            <p>No Andarilho skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Andarilho skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

  {{! Guerreiro Skills Table }}
  <div class="skill-table-container warrior-skills-table-container {{#unless system.details.showSkillsWarriorTable}}hidden{{/unless}}" data-warrior-skills-table-section style="margin-bottom: 20px;">
