{{! Skills Tab with Profession Recipe Tables }}
<section class='tab skills {{tab.cssClass}}' data-group='primary' data-tab='skills'>
  
  {{! Container Classes }}
  <div class='container-teste'>
    <h3>Classes</h3>
    
    {{! Classes Row }}
    <div class='classes-row'>
      <div class='class-field'>
        <label>ANDARILHO</label>
        <input
          type='number'
          name='system.classes.andarilho'
          value='{{system.classes.andarilho}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>GUERREIRO</label>
        <input
          type='number'
          name='system.classes.guerreiro'
          value='{{system.classes.guerreiro}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>LADINO</label>
        <input
          type='number'
          name='system.classes.ladino'
          value='{{system.classes.ladino}}'
          data-dtype='Number'
          min='0'
        />
      </div>
      <div class='class-field'>
        <label>FEITICEIRO</label>
        <input
          type='number'
          name='system.classes.feiticeiro'
          value='{{system.classes.feiticeiro}}'
          data-dtype='Number'
          min='0'
        />
      </div>
    </div>
  </div>

  {{! SKILL CLASS TABLE TOGGLES - Responsive layout }}
  <div class="skill-toggles-container">
    {{! Andarilho Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.AndarilhoSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsAndarilhoTable" {{checked system.details.showSkillsAndarilhoTable}} data-dtype="Boolean" data-andarilho-skills-table-toggle />
      <i class="fas fa-hiking {{#if system.details.showSkillsAndarilhoTable}}active{{/if}}" style="color: #8bc34a;"></i>
    </label>
    
    {{! Guerreiro Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.GuerreiroSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsGuerreiroTable" {{checked system.details.showSkillsGuerreiroTable}} data-dtype="Boolean" data-guerreiro-skills-table-toggle />
      <i class="fas fa-sword {{#if system.details.showSkillsGuerreiroTable}}active{{/if}}" style="color: #f44336;"></i>
    </label>
    
    {{! Ladino Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.LadinoSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsLadinoTable" {{checked system.details.showSkillsLadinoTable}} data-dtype="Boolean" data-ladino-skills-table-toggle />
      <i class="fas fa-mask {{#if system.details.showSkillsLadinoTable}}active{{/if}}" style="color: #9c27b0;"></i>
    </label>
    
    {{! Feiticeiro Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.FeiticeiroSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsFeiticeiroTable" {{checked system.details.showSkillsFeiticeiroTable}} data-dtype="Boolean" data-feiticeiro-skills-table-toggle />
      <i class="fas fa-magic {{#if system.details.showSkillsFeiticeiroTable}}active{{/if}}" style="color: #2196f3;"></i>
    </label>
    
    {{! Raciais Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.RaciaisSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsRaciaisTable" {{checked system.details.showSkillsRaciaisTable}} data-dtype="Boolean" data-raciais-skills-table-toggle />
      <i class="fas fa-users {{#if system.details.showSkillsRaciaisTable}}active{{/if}}" style="color: #ff9800;"></i>
    </label>
    
    {{! Únicas Skills Toggle }}
    <label class="icon-toggle" title="{{localize 'CARDIGAN.UnicasSkillsTable'}}">
      <input type="checkbox" name="system.details.showSkillsUnicasTable" {{checked system.details.showSkillsUnicasTable}} data-dtype="Boolean" data-unicas-skills-table-toggle />
      <i class="fas fa-star {{#if system.details.showSkillsUnicasTable}}active{{/if}}" style="color: #ffc107;"></i>
    </label>
  </div>

  {{! SKILL CLASS TABLES - All skill tables by class }}
  
  {{! Andarilho Skills Table }}
  <div class="skill-table-container andarilho-skills-table-container {{#unless system.details.showSkillsAndarilhoTable}}hidden{{/unless}}" data-andarilho-skills-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #8bc34a; text-align: center;">
      <i class="fas fa-hiking" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.AndarilhoSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-type'>Type</div>
        <div class='item-enhancements'>Enhancements</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Andarilho Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Andarilho Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsAndarilho as |skill id|}}
        <li
          class='item collapsible collapsed skill-item'
          data-item-id='{{skill._id}}'
          data-uuid='{{skill.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Skill Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{skill.img}}' title='{{skill.name}}' width='24' height='24'/>
              </div>
              <div 
                class="skill-name-hover"
                
                
                data-item-id="{{skill._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{skill.name}}
                {{#if skill.system.isPassive}}
                  <i class="fas fa-shield-alt" title="{{localize 'CARDIGAN.PassiveSkill'}}" style="color: #4caf50; margin-left: 5px;"></i>
                {{/if}}
              </div>
            </div>
            <div class='item-type'>
              {{#if skill.system.skillActionTypes}}
                <span class="skill-type-badge" style="padding: 2px 8px; border-radius: 4px; font-size: 11px; background: rgba(33,150,243,0.2); color: #2196f3;">
                  {{formatSkillActionTypes skill.system.skillActionTypes}}
                </span>
              {{/if}}
            </div>
            <div class='item-enhancements'>
              <div class="enhancement-checkboxes" style="display: flex; gap: 8px; justify-content: center;">
                <input type="checkbox" name="system.acquiredEnhancements.0" {{checked (lookup skill.system.acquiredEnhancements 0)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 1" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.1" {{checked (lookup skill.system.acquiredEnhancements 1)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 2" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.2" {{checked (lookup skill.system.acquiredEnhancements 2)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 3" style="width: 18px; height: 18px; cursor: pointer;" />
              </div>
            </div>
            <div class='item-controls'>
              <a class='item-control skill-chat' title='{{localize "CARDIGAN.ShowInChat"}}' data-action='skillToChat' data-item-id='{{skill._id}}'>
                <i class='fas fa-comment'></i>
              </a>
              {{#if @root.editable}}
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
                {{#unless (or skill.system.isLinkedSkill skill.system.enhancementLinkedSkill.isEnhancementLinked)}}
                  <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                  <i class='fas fa-trash'></i>
                </a>
                  {{/unless}}
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-hiking" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #8bc34a;"></i>
            <p>No Andarilho skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Andarilho skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

