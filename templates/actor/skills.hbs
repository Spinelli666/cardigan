{{! Skills Tab with Profession Recipe Tables }}
<section class='tab skills {{tab.cssClass}}' data-group='primary' data-tab='skills'>
  
  {{! PROFESSION TABLE TOGGLES - All checkboxes at the top }}
  <div class="profession-toggles-container" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 15px; margin-bottom: 30px; padding: 20px; background: rgba(0, 0, 0, 0.2); border-radius: 8px;">
    {{! Culinary Toggle }}
    <div class="profession-table-toggle culinary-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showCulinaryTable" {{checked system.details.showCulinaryTable}} data-dtype="Boolean" data-culinary-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-utensils" style="color: #ff6b35;"></i>
        {{localize "CARDIGAN.ShowCulinaryTable"}}
      </label>
    </div>
    
    {{! Tailoring Toggle }}
    <div class="profession-table-toggle tailoring-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showTailoringTable" {{checked system.details.showTailoringTable}} data-dtype="Boolean" data-tailoring-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-cut" style="color: #9c27b0;"></i>
        {{localize "CARDIGAN.ShowTailoringTable"}}
      </label>
    </div>
    
    {{! Tecnomagic Toggle }}
    <div class="profession-table-toggle tecnomagic-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showTecnomagicTable" {{checked system.details.showTecnomagicTable}} data-dtype="Boolean" data-tecnomagic-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-magic" style="color: #2196f3;"></i>
        {{localize "CARDIGAN.ShowTecnomagicTable"}}
      </label>
    </div>
    
    {{! Blacksmithing Toggle }}
    <div class="profession-table-toggle blacksmithing-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showBlacksmithingTable" {{checked system.details.showBlacksmithingTable}} data-dtype="Boolean" data-blacksmithing-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-hammer" style="color: #795548;"></i>
        {{localize "CARDIGAN.ShowBlacksmithingTable"}}
      </label>
    </div>
    
    {{! Alchemy Toggle }}
    <div class="profession-table-toggle alchemy-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showAlchemyTable" {{checked system.details.showAlchemyTable}} data-dtype="Boolean" data-alchemy-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-flask" style="color: #4caf50;"></i>
        {{localize "CARDIGAN.ShowAlchemyTable"}}
      </label>
    </div>
    
    {{! Carpentry Toggle }}
    <div class="profession-table-toggle carpentry-table-toggle">
      <label class="checkbox-label" style="display: flex; align-items: center; gap: 8px; color: #c9c7b8; font-size: 14px; cursor: pointer;">
        <input type="checkbox" name="system.details.showCarpentryTable" {{checked system.details.showCarpentryTable}} data-dtype="Boolean" data-carpentry-table-toggle style="transform: scale(1.2);" />
        <i class="fas fa-tools" style="color: #8bc34a;"></i>
        {{localize "CARDIGAN.ShowCarpentryTable"}}
      </label>
    </div>
  </div>

  {{! PROFESSION TABLES - All tables below }}
  
  {{! Culinary Table }}
  <div class="profession-table-container culinary-table-container {{#unless system.details.showCulinaryTable}}hidden{{/unless}}" data-culinary-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #ff6b35; text-align: center;">
      <i class="fas fa-utensils" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.CulinaryTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>{{localize "CARDIGAN.RecipeName"}}</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='{{localize "CARDIGAN.AddCulinaryRecipe"}}' data-action='createDoc' data-document-class='Item' data-type='culinary-recipe' data-name='New Culinary Recipe'>
              <i class='fas fa-plus'></i>
              {{localize "CARDIGAN.AddCulinaryRecipe"}}
            </a>
          {{/if}}
        </div>
      </li>
      {{#each culinaryRecipes as |recipe id|}}
        <li class='item flexrow' data-item-id='{{recipe._id}}'>
          <div class='item-name'>
            <div class='item-image'>
              <a class='rollable' data-action='cookRecipe' data-recipe-id='{{recipe._id}}'>
                <img src='{{recipe.img}}' title='{{recipe.name}}' width='24' height='24'/>
              </a>
            </div>
            <h4>{{recipe.name}}</h4>
          </div>
          <div class='item-controls'>
            {{#if @root.editable}}
              <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                <i class='fas fa-edit'></i>
              </a>
              <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                <i class='fas fa-trash'></i>
              </a>
            {{/if}}
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-utensils" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #ff6b35;"></i>
            <p>No culinary recipes learned yet.</p>
            <p style="font-size: 12px;">Click "Add Culinary Recipe" to start collecting recipes for cooking.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

