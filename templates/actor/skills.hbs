              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsWarrior as |skill id|}}
        {{> "systems/cardigan/templates/actor/partials/skill-row.hbs" skill=skill showEnhancements=true allowDelete=true}}
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-sword" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #f44336;"></i>
            <p>No Guerreiro skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Guerreiro skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

