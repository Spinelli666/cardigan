    <h3 class="items-section-header" style="margin-bottom: 10px; color: #ff9800; text-align: center;">
      <i class="fas fa-users" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.RaciaisSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-type'>Type</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Raciais Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Raciais Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsRaciais as |skill id|}}
        <li
          class='item collapsible collapsed skill-item'
          data-item-id='{{skill._id}}'
          data-uuid='{{skill.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Skill Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{skill.img}}' title='{{skill.name}}' width='24' height='24'/>
              </div>
              <div 
                class="skill-name-hover"
                
                
                data-item-id="{{skill._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{skill.name}}
                {{#if skill.system.isPassive}}
                  <i class="fas fa-shield-alt" title="{{localize 'CARDIGAN.PassiveSkill'}}" style="color: #4caf50; margin-left: 5px;"></i>
                {{/if}}
              </div>
            </div>
            <div class='item-type'>
              {{#if skill.system.skillActionTypes}}
                <span class="skill-type-badge" style="padding: 2px 8px; border-radius: 4px; font-size: 11px; background: rgba(33,150,243,0.2); color: #2196f3;">
                  {{formatSkillActionTypes skill.system.skillActionTypes}}
                </span>
              {{/if}}
            </div>
            <div class='item-controls'>
              <a class='item-control skill-chat' title='{{localize "CARDIGAN.ShowInChat"}}' data-action='skillToChat' data-item-id='{{skill._id}}'>
                <i class='fas fa-comment'></i>
              </a>
              {{#if @root.editable}}
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-users" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #ff9800;"></i>
            <p>No Raciais skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Raciais skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

  {{! Únicas Skills Table }}
  <div class="skill-table-container unicas-skills-table-container {{#unless system.details.showSkillsUnicasTable}}hidden{{/unless}}" data-unicas-skills-table-section style="margin-bottom: 20px;">
    <h3 class="items-section-header" style="margin-bottom: 10px; color: #ffc107; text-align: center;">
      <i class="fas fa-star" style="margin-right: 8px;"></i>
      {{localize "CARDIGAN.UnicasSkillsTable"}}
    </h3>
    <ol class='items-list'>
      <li class='item flexrow items-header'>
        <div class='item-name'>Skill Name</div>
        <div class='item-type'>Type</div>
        <div class='item-enhancements'>Enhancements</div>
        <div class='item-controls'>
          {{#if @root.editable}}
            <a class='item-control item-create' title='Add Únicas Skill' data-action='createDoc' data-document-class='Item' data-type='skill' data-name='New Únicas Skill'>
              <i class='fas fa-plus'></i>
              Add Skill
            </a>
          {{/if}}
        </div>
      </li>
      {{#each skillsUnicas as |skill id|}}
        <li
          class='item collapsible collapsed skill-item'
          data-item-id='{{skill._id}}'
          data-uuid='{{skill.uuid}}'
          data-drag='true'
          data-document-class='Item'
        >
          {{!-- Skill Row Summary --}}
          <div class="item-row flexrow">
            <div class='item-name'>
              <div class='item-image'>
                <img src='{{skill.img}}' title='{{skill.name}}' width='24' height='24'/>
              </div>
              <div 
                class="skill-name-hover"
                
                
                data-item-id="{{skill._id}}"
                data-action="toggleExpand"
                style="cursor: pointer;"
              >
                {{skill.name}}
                {{#if skill.system.isPassive}}
                  <i class="fas fa-shield-alt" title="{{localize 'CARDIGAN.PassiveSkill'}}" style="color: #4caf50; margin-left: 5px;"></i>
                {{/if}}
              </div>
            </div>
            <div class='item-type'>
              {{#if skill.system.skillActionTypes}}
                <span class="skill-type-badge" style="padding: 2px 8px; border-radius: 4px; font-size: 11px; background: rgba(33,150,243,0.2); color: #2196f3;">
                  {{formatSkillActionTypes skill.system.skillActionTypes}}
                </span>
              {{/if}}
            </div>
            <div class='item-enhancements'>
              <div class="enhancement-checkboxes" style="display: flex; gap: 8px; justify-content: center;">
                <input type="checkbox" name="system.acquiredEnhancements.0" {{checked (lookup skill.system.acquiredEnhancements 0)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 1" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.1" {{checked (lookup skill.system.acquiredEnhancements 1)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 2" style="width: 18px; height: 18px; cursor: pointer;" />
                <input type="checkbox" name="system.acquiredEnhancements.2" {{checked (lookup skill.system.acquiredEnhancements 2)}} data-dtype="Boolean" data-item-id="{{skill._id}}" title="Enhancement 3" style="width: 18px; height: 18px; cursor: pointer;" />
              </div>
            </div>
            <div class='item-controls'>
              <a class='item-control skill-chat' title='{{localize "CARDIGAN.ShowInChat"}}' data-action='skillToChat' data-item-id='{{skill._id}}'>
                <i class='fas fa-comment'></i>
              </a>
              {{#if @root.editable}}
                <a class='item-control item-edit' title='{{localize "CARDIGAN.EditItem"}}' data-action='editDoc' data-document-class='Item'>
                  <i class='fas fa-edit'></i>
                </a>
                {{#unless (or skill.system.isLinkedSkill skill.system.enhancementLinkedSkill.isEnhancementLinked)}}
                  <a class='item-control item-delete' title='{{localize "CARDIGAN.DeleteItem"}}' data-action='deleteDoc' data-document-class='Item'>
                  <i class='fas fa-trash'></i>
                </a>
                  {{/unless}}
              {{/if}}
            </div>
          </div>
          
          {{!-- Expandable Description --}}
          <div class="item-description">
            <div class="wrapper">
              {{!-- Expanded content will be loaded here dynamically --}}
            </div>
          </div>
        </li>
      {{else}}
        <li class='item flexrow empty-state' style='text-align: center; padding: 20px; color: #a59b85;'>
          <div style='width: 100%;'>
            <i class="fas fa-star" style="font-size: 24px; margin-bottom: 10px; opacity: 0.5; color: #ffc107;"></i>
            <p>No Únicas skills learned yet.</p>
            <p style="font-size: 12px;">Click "Add Skill" to start collecting Únicas skills.</p>
          </div>
        </li>
      {{/each}}
    </ol>
  </div>

</section>