{{! Modifiers Tab for Consumable Items }}
<section
  class='tab modifiers {{tab.cssClass}}'
  data-group='primary'
  data-tab='modifiers'
>
  {{! Checkbox to control skill check visibility }}
  <div class="skill-check-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasSkillCheck" {{checked item.system.hasSkillCheck}} data-dtype="Boolean" data-skill-check-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasSkillCheck"}}
    </label>
  </div>

  {{! Skill Check System }}
  <div class="skill-check-system {{#unless item.system.hasSkillCheck}}hidden{{/unless}}" data-skill-check-section>
    <div class="form-group skill-selection">
      <label>{{localize "CARDIGAN.ItemConsumivel.SkillCheckAbility"}}</label>
      <select name="system.skillCheckAbility" data-dtype="String">
        <option value="accuracy" {{#if (eq item.system.skillCheckAbility "accuracy")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Accuracy.long"}}</option>
        <option value="evasion" {{#if (eq item.system.skillCheckAbility "evasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Evasion.long"}}</option>
        <option value="strength" {{#if (eq item.system.skillCheckAbility "strength")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Strength.long"}}</option>
        <option value="dexterity" {{#if (eq item.system.skillCheckAbility "dexterity")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Dexterity.long"}}</option>
        <option value="stamina" {{#if (eq item.system.skillCheckAbility "stamina")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stamina.long"}}</option>
        <option value="stealth" {{#if (eq item.system.skillCheckAbility "stealth")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stealth.long"}}</option>
        <option value="persuasion" {{#if (eq item.system.skillCheckAbility "persuasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Persuasion.long"}}</option>
        <option value="intelligence" {{#if (eq item.system.skillCheckAbility "intelligence")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Intelligence.long"}}</option>
        <option value="psionics" {{#if (eq item.system.skillCheckAbility "psionics")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Psionics.long"}}</option>
      </select>
    </div>
    
    <div class="form-group advantage-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.skillCheckAdvantage" {{checked item.system.skillCheckAdvantage}} data-dtype="Boolean" />
        {{localize "CARDIGAN.ItemConsumivel.SkillCheckAdvantage"}}
      </label>
    </div>
  </div>

  <div class="skill-check-system {{#unless item.system.hasSkillCheck}}hidden{{/unless}}" data-skill-check-section>
    {{! Critical Failure Effects System }}
    <div class="critical-failure-effects-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.hasCriticalFailureEffects" {{checked item.system.hasCriticalFailureEffects}} data-dtype="Boolean" data-critical-failure-effects-toggle />
        {{localize "CARDIGAN.ItemConsumivel.HasCriticalFailureEffects"}}
      </label>
    </div>

    <div class="critical-failure-effects-system {{#unless item.system.hasCriticalFailureEffects}}hidden{{/unless}}" data-critical-failure-effects-section>
      <div class="form-group critical-failure-effects">
        <button type="button" data-action="configureCriticalFailureEffects" >
          <i class="fas fa-cog"></i> {{localize "CARDIGAN.ItemConsumivel.ConfigureEffects"}}
        </button>
        
        {{#if item.system.criticalFailureEffects.length}}
        <div class="selected-effects">
          <h4>{{localize "CARDIGAN.ItemConsumivel.SelectedEffects"}}</h4>
          <div class="effects-list">
            {{#each item.system.criticalFailureEffects}}
            <div class="effect-item">
              <img src="{{img}}" alt="{{name}}" width="24" height="24">
              <span>{{name}}</span>
            </div>
            {{/each}}
          </div>
        </div>
        {{else}}
        <div class="no-effects">
          <em>{{localize "CARDIGAN.NoEffectsSelected"}}</em>
        </div>
        {{/if}}
      </div>
    </div>

    {{! Critical Failure Skill Loss System }}
    <div class="critical-failure-skill-loss-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.hasCriticalFailureSkillLoss" {{checked item.system.hasCriticalFailureSkillLoss}} data-dtype="Boolean" data-critical-failure-skill-loss-toggle />
        {{localize "CARDIGAN.ItemConsumivel.HasCriticalFailureSkillLoss"}}
      </label>
    </div>

    <div class="critical-failure-skill-loss-system {{#unless item.system.hasCriticalFailureSkillLoss}}hidden{{/unless}}" data-critical-failure-skill-loss-section>
      <div class="form-group critical-failure-skill-loss">
        <div class="critical-failure-skill-loss-header">
          <label>{{localize "CARDIGAN.ItemConsumivel.CriticalFailureSkillLoss"}}</label>
          <button type="button" class="add-critical-failure-skill-loss-btn" data-action="addCriticalFailureSkillLoss" title="{{localize 'CARDIGAN.ItemConsumivel.AddCriticalFailureSkillLoss'}}">+</button>
        </div>
        
        <div class="critical-failure-skill-loss-list" data-critical-failure-skill-loss-container>
          {{#each item.system.criticalFailureSkillLoss as |skillLoss index|}}
            <div class="critical-failure-skill-loss-row" data-critical-failure-skill-loss-index="{{index}}">
              <div class="skill-loss-controls">
                <div class="skill-loss-ability">
                  <label>{{localize "CARDIGAN.ItemConsumivel.CriticalFailureSkillLossAbility"}}</label>
                  <select name="system.criticalFailureSkillLoss.{{index}}.ability" data-critical-failure-skill-loss-ability-select>
                    <option value="accuracy" {{#if (eq skillLoss.ability "accuracy")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Accuracy.long"}}</option>
                    <option value="evasion" {{#if (eq skillLoss.ability "evasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Evasion.long"}}</option>
                    <option value="strength" {{#if (eq skillLoss.ability "strength")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Strength.long"}}</option>
                    <option value="dexterity" {{#if (eq skillLoss.ability "dexterity")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Dexterity.long"}}</option>
                    <option value="stamina" {{#if (eq skillLoss.ability "stamina")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stamina.long"}}</option>
                    <option value="stealth" {{#if (eq skillLoss.ability "stealth")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stealth.long"}}</option>
                    <option value="persuasion" {{#if (eq skillLoss.ability "persuasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Persuasion.long"}}</option>
                    <option value="intelligence" {{#if (eq skillLoss.ability "intelligence")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Intelligence.long"}}</option>
                    <option value="psionics" {{#if (eq skillLoss.ability "psionics")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Psionics.long"}}</option>
                  </select>
                </div>
                <div class="skill-loss-value">
                  <label>{{localize "CARDIGAN.ItemConsumivel.CriticalFailureSkillLossValue"}}</label>
                  <input type="number" name="system.criticalFailureSkillLoss.{{index}}.value" value="{{skillLoss.value}}" min="1" data-dtype="Number" />
                </div>
              </div>
              <button type="button" class="remove-critical-failure-skill-loss-btn" data-action="removeCriticalFailureSkillLoss" data-index="{{index}}" title="{{localize 'CARDIGAN.ItemConsumivel.RemoveCriticalFailureSkillLoss'}}">−</button>
            </div>
          {{/each}}
        </div>
        
        {{#unless item.system.criticalFailureSkillLoss.length}}
          <div class="no-critical-failure-skill-loss-message">
            {{localize "CARDIGAN.NoSkillLossAdded"}}
          </div>
        {{/unless}}
      </div>
    </div>

    {{! Critical Hit Effects System }}
    <div class="critical-hit-effects-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.hasCriticalHitEffects" {{checked item.system.hasCriticalHitEffects}} data-dtype="Boolean" data-critical-hit-effects-toggle />
        {{localize "CARDIGAN.ItemConsumivel.HasCriticalHitEffects"}}
      </label>
    </div>

    <div class="critical-hit-effects-system {{#unless item.system.hasCriticalHitEffects}}hidden{{/unless}}" data-critical-hit-effects-section>
      <div class="form-group critical-hit-effects">
        <button type="button" data-action="configureCriticalHitEffects" >
          <i class="fas fa-cog"></i> {{localize "CARDIGAN.ItemConsumivel.ConfigureEffects"}}
        </button>
        
        {{#if item.system.criticalHitEffects.length}}
        <div class="selected-effects">
          <h4>{{localize "CARDIGAN.ItemConsumivel.SelectedEffects"}}</h4>
          <div class="effects-list">
            {{#each item.system.criticalHitEffects}}
            <div class="effect-item">
              <img src="{{img}}" alt="{{name}}" width="24" height="24">
              <span>{{name}}</span>
            </div>
            {{/each}}
          </div>
        </div>
        {{else}}
        <div class="no-effects">
          <em>{{localize "CARDIGAN.NoEffectsSelected"}}</em>
        </div>
        {{/if}}
      </div>
    </div>

    {{! Critical Hit Skill Bonus System }}
    <div class="critical-hit-skill-bonus-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.hasCriticalHitSkillBonus" {{checked item.system.hasCriticalHitSkillBonus}} data-dtype="Boolean" data-critical-hit-skill-bonus-toggle />
        {{localize "CARDIGAN.ItemConsumivel.HasCriticalHitSkillBonus"}}
      </label>
    </div>

    <div class="critical-hit-skill-bonus-system {{#unless item.system.hasCriticalHitSkillBonus}}hidden{{/unless}}" data-critical-hit-skill-bonus-section>
      <div class="form-group critical-hit-skill-bonus">
        <div class="critical-hit-skill-bonus-header">
          <label>{{localize "CARDIGAN.ItemConsumivel.CriticalHitSkillBonus"}}</label>
          <button type="button" class="add-critical-hit-skill-bonus-btn" data-action="addCriticalHitSkillBonus" title="{{localize 'CARDIGAN.ItemConsumivel.AddCriticalHitSkillBonus'}}">+</button>
        </div>
        
        <div class="critical-hit-skill-bonus-list" data-critical-hit-skill-bonus-container>
          {{#each item.system.criticalHitSkillBonus as |skillBonus index|}}
            <div class="critical-hit-skill-bonus-row" data-critical-hit-skill-bonus-index="{{index}}">
              <div class="skill-bonus-controls">
                <div class="skill-bonus-ability">
                  <label>{{localize "CARDIGAN.ItemConsumivel.CriticalHitSkillBonusAbility"}}</label>
                  <select name="system.criticalHitSkillBonus.{{index}}.ability" data-critical-hit-skill-bonus-ability-select>
                    <option value="accuracy" {{#if (eq skillBonus.ability "accuracy")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Accuracy.long"}}</option>
                    <option value="evasion" {{#if (eq skillBonus.ability "evasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Evasion.long"}}</option>
                    <option value="strength" {{#if (eq skillBonus.ability "strength")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Strength.long"}}</option>
                    <option value="dexterity" {{#if (eq skillBonus.ability "dexterity")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Dexterity.long"}}</option>
                    <option value="stamina" {{#if (eq skillBonus.ability "stamina")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stamina.long"}}</option>
                    <option value="stealth" {{#if (eq skillBonus.ability "stealth")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stealth.long"}}</option>
                    <option value="persuasion" {{#if (eq skillBonus.ability "persuasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Persuasion.long"}}</option>
                    <option value="intelligence" {{#if (eq skillBonus.ability "intelligence")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Intelligence.long"}}</option>
                    <option value="psionics" {{#if (eq skillBonus.ability "psionics")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Psionics.long"}}</option>
                  </select>
                </div>
                <div class="skill-bonus-value">
                  <label>{{localize "CARDIGAN.ItemConsumivel.CriticalHitSkillBonusValue"}}</label>
                  <input type="number" name="system.criticalHitSkillBonus.{{index}}.value" value="{{skillBonus.value}}" min="1" data-dtype="Number" />
                </div>
              </div>
              <button type="button" class="remove-critical-hit-skill-bonus-btn" data-action="removeCriticalHitSkillBonus" data-index="{{index}}" title="{{localize 'CARDIGAN.ItemConsumivel.RemoveCriticalHitSkillBonus'}}">−</button>
            </div>
          {{/each}}
        </div>
        
        {{#unless item.system.criticalHitSkillBonus.length}}
          <div class="no-critical-hit-skill-bonus-message">
            {{localize "CARDIGAN.NoSkillBonusAdded"}}
          </div>
        {{/unless}}
      </div>
    </div>
  </div>

  {{! Temporary Skill Bonus System - Independent of Skill Check }}
  <div class="temporary-skill-bonus-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasTemporarySkillBonus" {{checked item.system.hasTemporarySkillBonus}} data-dtype="Boolean" data-temporary-skill-bonus-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasTemporarySkillBonus"}}
    </label>
  </div>

  <div class="temporary-skill-bonus-system {{#unless item.system.hasTemporarySkillBonus}}hidden{{/unless}}" data-temporary-skill-bonus-section>
    <div class="form-group temporary-skill-bonus">
      <div class="temporary-skill-bonus-header">
        <label>{{localize "CARDIGAN.ItemConsumivel.TemporarySkillBonus"}}</label>
        <button type="button" class="add-temporary-skill-bonus-btn" data-action="addTemporarySkillBonus" title="{{localize 'CARDIGAN.ItemConsumivel.AddTemporarySkillBonus'}}">+</button>
      </div>
      
      <div class="temporary-skill-bonus-list" data-temporary-skill-bonus-container>
        {{#each item.system.temporarySkillBonus as |skillBonus index|}}
          <div class="temporary-skill-bonus-row" data-temporary-skill-bonus-index="{{index}}">
            <div class="skill-bonus-controls">
              <div class="skill-bonus-ability">
                <label>{{localize "CARDIGAN.ItemConsumivel.TemporarySkillBonusAbility"}}</label>
                <select name="system.temporarySkillBonus.{{index}}.ability" data-temporary-skill-bonus-ability-select>
                  <option value="accuracy" {{#if (eq skillBonus.ability "accuracy")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Accuracy.long"}}</option>
                  <option value="evasion" {{#if (eq skillBonus.ability "evasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Evasion.long"}}</option>
                  <option value="strength" {{#if (eq skillBonus.ability "strength")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Strength.long"}}</option>
                  <option value="dexterity" {{#if (eq skillBonus.ability "dexterity")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Dexterity.long"}}</option>
                  <option value="stamina" {{#if (eq skillBonus.ability "stamina")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stamina.long"}}</option>
                  <option value="stealth" {{#if (eq skillBonus.ability "stealth")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stealth.long"}}</option>
                  <option value="persuasion" {{#if (eq skillBonus.ability "persuasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Persuasion.long"}}</option>
                  <option value="intelligence" {{#if (eq skillBonus.ability "intelligence")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Intelligence.long"}}</option>
                  <option value="psionics" {{#if (eq skillBonus.ability "psionics")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Psionics.long"}}</option>
                </select>
              </div>
              <div class="skill-bonus-value">
                <label>{{localize "CARDIGAN.ItemConsumivel.TemporarySkillBonusValue"}}</label>
                <input type="number" name="system.temporarySkillBonus.{{index}}.value" value="{{skillBonus.value}}" min="1" data-dtype="Number" />
              </div>
            </div>
            <button type="button" class="remove-temporary-skill-bonus-btn" data-action="removeTemporarySkillBonus" data-index="{{index}}" title="{{localize 'CARDIGAN.ItemConsumivel.RemoveTemporarySkillBonus'}}">−</button>
          </div>
        {{/each}}
      </div>
      
      {{#unless item.system.temporarySkillBonus.length}}
        <div class="no-temporary-skill-bonus-message">
          {{localize "CARDIGAN.NoSkillBonusAdded"}}
        </div>
      {{/unless}}
    </div>
  </div>

  {{! Health Modifier System - Buff/Debuff Health }}
  <div class="health-modifier-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasHealthModifier" {{checked item.system.hasHealthModifier}} data-dtype="Boolean" data-health-modifier-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasHealthModifier"}}
    </label>
  </div>

  <div class="health-modifier-system {{#unless item.system.hasHealthModifier}}hidden{{/unless}}" data-health-modifier-section>
    <div class="form-group health-modifier">
      <div class="health-modifier-checkboxes">
        <label class="checkbox-label">
          <input type="radio" name="system.healthModifierType" value="add" {{#if (eq item.system.healthModifierType "add")}}checked{{/if}} data-dtype="String" />
          {{localize "CARDIGAN.ItemConsumivel.HealthAdd"}}
        </label>
        <label class="checkbox-label">
          <input type="radio" name="system.healthModifierType" value="subtract" {{#if (eq item.system.healthModifierType "subtract")}}checked{{/if}} data-dtype="String" />
          {{localize "CARDIGAN.ItemConsumivel.HealthSubtract"}}
        </label>
      </div>
      
      <div class="health-modifier-dice">
        <label>{{localize "CARDIGAN.ItemConsumivel.HealthModifierDice"}}</label>
        <select name="system.healthModifierDice" data-dtype="String">
          <option value="1d20" {{#if (eq item.system.healthModifierDice "1d20")}}selected{{/if}}>1d20</option>
          <option value="1d12" {{#if (eq item.system.healthModifierDice "1d12")}}selected{{/if}}>1d12</option>
          <option value="1d10" {{#if (eq item.system.healthModifierDice "1d10")}}selected{{/if}}>1d10</option>
          <option value="1d8" {{#if (eq item.system.healthModifierDice "1d8")}}selected{{/if}}>1d8</option>
          <option value="1d6" {{#if (eq item.system.healthModifierDice "1d6")}}selected{{/if}}>1d6</option>
          <option value="1d4" {{#if (eq item.system.healthModifierDice "1d4")}}selected{{/if}}>1d4</option>
        </select>
      </div>
      
      <div class="health-modifier-quantity">
        <label>{{localize "CARDIGAN.ItemConsumivel.HealthModifierQuantity"}}</label>
        <input type="number" name="system.healthModifierQuantity" value="{{item.system.healthModifierQuantity}}" min="1" max="10" data-dtype="Number" />
      </div>
      
      <div class="health-modifier-additional-bonus">
        <label>{{localize "CARDIGAN.ItemConsumivel.HealthModifierAdditionalBonus"}}</label>
        <input type="number" name="system.healthModifierAdditionalBonus" value="{{item.system.healthModifierAdditionalBonus}}" min="0" data-dtype="Number" />
      </div>
      
      <div class="health-modifier-skill-toggle">
        <label class="checkbox-label">
          <input type="checkbox" name="system.healthModifierAddSkill" {{checked item.system.healthModifierAddSkill}} data-dtype="Boolean" data-health-modifier-skill-toggle />
          {{localize "CARDIGAN.ItemConsumivel.HealthModifierAddSkill"}}
        </label>
      </div>
      
      <div class="health-modifier-skill-system {{#unless item.system.healthModifierAddSkill}}hidden{{/unless}}" data-health-modifier-skill-section>
        <div class="health-modifier-skill-controls">
          <div class="health-modifier-skill-selection">
            <label>{{localize "CARDIGAN.ItemConsumivel.HealthModifierSkill"}}</label>
            <select name="system.healthModifierSkill" data-dtype="String">
              <option value="accuracy" {{#if (eq item.system.healthModifierSkill "accuracy")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Accuracy.long"}}</option>
              <option value="evasion" {{#if (eq item.system.healthModifierSkill "evasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Evasion.long"}}</option>
              <option value="strength" {{#if (eq item.system.healthModifierSkill "strength")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Strength.long"}}</option>
              <option value="dexterity" {{#if (eq item.system.healthModifierSkill "dexterity")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Dexterity.long"}}</option>
              <option value="stamina" {{#if (eq item.system.healthModifierSkill "stamina")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stamina.long"}}</option>
              <option value="stealth" {{#if (eq item.system.healthModifierSkill "stealth")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Stealth.long"}}</option>
              <option value="persuasion" {{#if (eq item.system.healthModifierSkill "persuasion")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Persuasion.long"}}</option>
              <option value="intelligence" {{#if (eq item.system.healthModifierSkill "intelligence")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Intelligence.long"}}</option>
              <option value="psionics" {{#if (eq item.system.healthModifierSkill "psionics")}}selected{{/if}}>{{localize "CARDIGAN.Ability.Psionics.long"}}</option>
            </select>
          </div>
          
          <div class="health-modifier-double-toggle">
            <label class="checkbox-label">
              <input type="checkbox" name="system.healthModifierDoubleSkill" {{checked item.system.healthModifierDoubleSkill}} data-dtype="Boolean" />
              {{localize "CARDIGAN.ItemConsumivel.HealthModifierDoubleSkill"}}
            </label>
          </div>
        </div>
      </div>
      
      <div class="health-modifier-temporary-toggle">
        <label class="checkbox-label">
          <input type="checkbox" name="system.healthModifierIsTemporary" {{checked item.system.healthModifierIsTemporary}} data-dtype="Boolean" />
          {{localize "CARDIGAN.ItemConsumivel.HealthModifierIsTemporary"}}
        </label>
      </div>
    </div>
  </div>

  {{! Energy Modifier System - Buff/Debuff Energy }}
  <div class="energy-modifier-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasEnergyModifier" {{checked item.system.hasEnergyModifier}} data-dtype="Boolean" data-energy-modifier-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasEnergyModifier"}}
    </label>
  </div>

  <div class="energy-modifier-system {{#unless item.system.hasEnergyModifier}}hidden{{/unless}}" data-energy-modifier-section>
    <div class="form-group energy-modifier">
      <div class="energy-modifier-checkboxes">
        <label class="checkbox-label">
          <input type="radio" name="system.energyModifierType" value="add" {{#if (eq item.system.energyModifierType "add")}}checked{{/if}} data-dtype="String" />
          {{localize "CARDIGAN.ItemConsumivel.EnergyModifierTypeAdd"}}
        </label>
        <label class="checkbox-label">
          <input type="radio" name="system.energyModifierType" value="subtract" {{#if (eq item.system.energyModifierType "subtract")}}checked{{/if}} data-dtype="String" />
          {{localize "CARDIGAN.ItemConsumivel.EnergyModifierTypeSubtract"}}
        </label>
      </div>
      
      <div class="energy-modifier-dice">
        <label>{{localize "CARDIGAN.ItemConsumivel.EnergyModifierDice"}}</label>
        <select name="system.energyModifierDice" data-dtype="String">
          <option value="1d20" {{#if (eq item.system.energyModifierDice "1d20")}}selected{{/if}}>1d20</option>
          <option value="1d12" {{#if (eq item.system.energyModifierDice "1d12")}}selected{{/if}}>1d12</option>
          <option value="1d10" {{#if (eq item.system.energyModifierDice "1d10")}}selected{{/if}}>1d10</option>
          <option value="1d8" {{#if (eq item.system.energyModifierDice "1d8")}}selected{{/if}}>1d8</option>
