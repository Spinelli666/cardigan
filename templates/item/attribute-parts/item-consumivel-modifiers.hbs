            <input type="radio" name="system.fractureModifierType" value="increase" {{#if (eq item.system.fractureModifierType "increase")}}checked{{/if}} data-dtype="String" />
            {{localize "CARDIGAN.ItemConsumivel.FractureIncrease"}}
          </label>
          <label class="checkbox-label">
            <input type="radio" name="system.fractureModifierType" value="decrease" {{#if (eq item.system.fractureModifierType "decrease")}}checked{{/if}} data-dtype="String" />
            {{localize "CARDIGAN.ItemConsumivel.FractureDecrease"}}
          </label>
        </div>
