  {{! Checkbox to control effects visibility }}
  <div class="effects-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasEffects" {{checked item.system.hasEffects}} data-dtype="Boolean" data-effects-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasEffects"}}
    </label>
  </div>

  {{! Movement Boost System }}
  <div class="movement-boost-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasMovementBoost" {{checked item.system.hasMovementBoost}} data-dtype="Boolean" data-movement-boost-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasMovementBoost"}}
    </label>
  </div>

  <div class="movement-boost-system {{#unless item.system.hasMovementBoost}}hidden{{/unless}}" data-movement-boost-section>
    <div class="form-group movement-boost-amount">
      <label for="system.movementBoostAmount">{{localize "CARDIGAN.ItemConsumivel.MovementBoostAmount"}}</label>
      <input type="number" name="system.movementBoostAmount" value="{{item.system.movementBoostAmount}}" data-dtype="Number" min="1" max="10" />
    </div>
  </div>

  {{! Critical Hit Boost System }}
  <div class="critical-hit-boost-toggle">
    <label class="checkbox-label">
      <input type="checkbox" name="system.hasCriticalHitBoost" {{checked item.system.hasCriticalHitBoost}} data-dtype="Boolean" data-critical-hit-boost-toggle />
      {{localize "CARDIGAN.ItemConsumivel.HasCriticalHitBoost"}}
    </label>
  </div>

  <div class="critical-hit-boost-system {{#unless item.system.hasCriticalHitBoost}}hidden{{/unless}}" data-critical-hit-boost-section>
    <div class="form-group critical-hit-boost-amount">
      <label for="system.criticalHitBoostAmount">{{localize "CARDIGAN.ItemConsumivel.CriticalHitBoostAmount"}}</label>
      <input type="number" name="system.criticalHitBoostAmount" value="{{item.system.criticalHitBoostAmount}}" data-dtype="Number" min="1" max="5" />
    </div>
  </div>

  {{! Effects System - Similar to Skill Bonuses }}
  <div class="effects-system {{#unless item.system.hasEffects}}hidden{{/unless}}" data-effects-section>
    <div class="form-group item-effects">
      <div class="effects-header">
        <label>{{localize "CARDIGAN.Effects"}}</label>
        <button type="button" class="add-effect-btn" data-action="addEffect" title="{{localize 'CARDIGAN.AddEffect'}}">+</button>
      </div>
      
      <div class="effects-list" data-effects-container>
        {{#each item.system.effects as |effect index|}}
          <div class="effect-row" data-effect-index="{{index}}">
            <select name="system.effects.{{index}}.effectId" data-effect-select>
              <option value="">{{localize "CARDIGAN.SelectEffect"}}</option>
              {{#each @root.availableEffects as |availableEffect|}}
                <option value="{{availableEffect.id}}" {{#if (eq effect.effectId availableEffect.id)}}selected{{/if}}>
                  {{availableEffect.name}}
                </option>
              {{/each}}
            </select>
            <div class="effect-checkboxes">
              <label class="checkbox-label">
                <input type="checkbox" name="system.effects.{{index}}.apply" {{checked effect.apply}} data-dtype="Boolean" data-effect-checkbox="apply" data-effect-index="{{index}}"/>
                {{localize "CARDIGAN.Apply"}}
              </label>
              <label class="checkbox-label">
                <input type="checkbox" name="system.effects.{{index}}.remove" {{checked effect.remove}} data-dtype="Boolean" data-effect-checkbox="remove" data-effect-index="{{index}}"/>
                {{localize "CARDIGAN.Remove"}}
              </label>
            </div>
            <button type="button" class="remove-effect-btn" data-action="removeEffect" data-index="{{index}}" title="{{localize 'CARDIGAN.RemoveEffect'}}">−</button>
          </div>
        {{/each}}
      </div>
      
      {{#unless item.system.effects.length}}
        <div class="no-effects-message">
          {{localize "CARDIGAN.NoEffectsAdded"}}
        </div>
      {{/unless}}
    </div>
  </div>

</section>