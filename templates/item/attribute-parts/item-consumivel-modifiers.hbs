  <div class="food-and-water-system {{#unless item.system.hasFoodAndWater}}hidden{{/unless}}" data-food-and-water-section>
    {{! Food Modifier Toggle }}
    <div class="food-modifier-toggle">
      <label class="checkbox-label">
        <input type="checkbox" name="system.hasFoodModifier" {{checked item.system.hasFoodModifier}} data-dtype="Boolean" data-food-modifier-toggle />
        {{localize "CARDIGAN.ItemConsumivel.HasFoodModifier"}}
      </label>
