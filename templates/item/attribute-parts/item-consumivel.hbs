    <div class="consumable-item-bottom-column">
      <div class="consumable-item-check-skill-wrapper">
        <div class="consumable-item-check-skill">
          <p>VIDA & ENERGIA</p>
          <label class="consumable-item-check-skill-toggle armor-extra-content consumable-item-special-content" aria-label="Ativar vida e energia" data-tooltip="Ativar" data-tooltip-class='cardigan-tooltip'>
            <input type="checkbox" name="system.hasLifeEnergySection" {{checked system.hasLifeEnergySection}} data-dtype="Boolean" data-life-energy-toggle class="consumable-item-check-skill-checkbox" />
            <img
              class="consumable-item-check-skill-icon armor-extra-icon consumable-item-special-icon"
              src="systems/cardigan/assets/images/decorative/icons/icon-equip.svg"
              alt="Ativar vida e energia"
            />
          </label>
        </div>
        <img class="consumable-item-check-skill-border" src="systems/cardigan/assets/images/decorative/border.webp" alt="Borda decorativa" />
      </div>
      <div class="consumable-item-life-energy-system {{#unless system.hasLifeEnergySection}}hidden{{/unless}}" data-life-energy-section>
        <div class="consumable-item-life-energy-add-button-container">
          <button type="button" class="consumable-item-life-energy-add-button" aria-label="Adicionar" data-tooltip="Adicionar" data-tooltip-class="cardigan-tooltip">
            <img
              src="systems/cardigan/assets/images/decorative/icons/icon-add-effects.svg"
              alt="Adicionar"
              class="consumable-item-life-energy-add-icon"
            />
          </button>
        </div>
      </div>
    </div>
    <div class="consumable-item-bottom-column"></div>
