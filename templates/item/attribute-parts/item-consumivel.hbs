        <div class="consumable-item-skill-test-advantage-controls">
          <label class="consumable-item-skill-test-advantage-toggle" aria-label="Desvantagem aprimorada" data-tooltip="Desvantagem Aprimorada" data-tooltip-class='cardigan-tooltip'>
            <input
              type="checkbox"
              name="system.skillCheckEnhancedDisadvantage"
              {{checked system.skillCheckEnhancedDisadvantage}}
              data-dtype="Boolean"
              class="consumable-item-skill-test-advantage-checkbox"
            />
            <img
              class="consumable-item-skill-test-advantage-icon"
              src="systems/cardigan/assets/images/decorative/icons/icon-enhanced-disadvantage.svg"
              alt="Desvantagem aprimorada"
            />
          </label>
          <label class="consumable-item-skill-test-advantage-toggle" aria-label="Desvantagem" data-tooltip="Desvantagem" data-tooltip-class='cardigan-tooltip'>
            <input
              type="checkbox"
              name="system.skillCheckDisadvantage"
              {{checked system.skillCheckDisadvantage}}
              data-dtype="Boolean"
              class="consumable-item-skill-test-advantage-checkbox"
            />
            <img
              class="consumable-item-skill-test-advantage-icon"
              src="systems/cardigan/assets/images/decorative/icons/icon-disadvantage.svg"
              alt="Desvantagem"
            />
          </label>
          <label class="consumable-item-skill-test-advantage-toggle" aria-label="Vantagem" data-tooltip="Vantagem" data-tooltip-class='cardigan-tooltip'>
            <input
              type="checkbox"
              name="system.skillCheckAdvantage"
              {{checked system.skillCheckAdvantage}}
              data-dtype="Boolean"
              class="consumable-item-skill-test-advantage-checkbox"
            />
            <img
              class="consumable-item-skill-test-advantage-icon"
              src="systems/cardigan/assets/images/decorative/icons/icon-advantage.svg"
              alt="Vantagem"
            />
          </label>
          <label class="consumable-item-skill-test-advantage-toggle" aria-label="Vantagem aprimorada" data-tooltip="Vantagem Aprimorada" data-tooltip-class='cardigan-tooltip'>
            <input
              type="checkbox"
              name="system.skillCheckEnhancedAdvantage"
              {{checked system.skillCheckEnhancedAdvantage}}
              data-dtype="Boolean"
              class="consumable-item-skill-test-advantage-checkbox"
            />
            <img
              class="consumable-item-skill-test-advantage-icon"
              src="systems/cardigan/assets/images/decorative/icons/icon-enhanced-advantage.svg"
              alt="Vantagem aprimorada"
            />
          </label>
        </div>
        <div class="consumable-item-skill-test-add-button-container">
          <button type="button" class="consumable-item-skill-test-add-button" aria-label="Adicionar" data-tooltip="Adicionar" data-tooltip-class="cardigan-tooltip">
            <img
              src="systems/cardigan/assets/images/decorative/icons/icon-add-effects.svg"
              alt="Adicionar"
              class="consumable-item-skill-test-add-icon"
            />
          </button>
        </div>
        <div class="consumable-item-skill-test-added-content"></div>
      </div>
