{{!-- 
Template para itens do tipo arma com sistema de propriedades dinâmicas
--}}
<div class="tab-content" data-tab="attributes">
    <div class="form-group">
        <label for="system.rightHand">{{localize "CARDIGAN.RightHand"}}</label>
        <input type="checkbox" name="system.rightHand" {{checked item.system.rightHand}}/>
    </div>

    <div class="form-group">
        <label for="system.leftHand">{{localize "CARDIGAN.LeftHand"}}</label>
        <input type="checkbox" name="system.leftHand" {{checked item.system.leftHand}}/>
    </div>

    <div class="form-group">
        <label for="system.damage.value">{{localize "CARDIGAN.Damage"}}</label>
        <input type="text" name="system.damage.value" value="{{item.system.damage.value}}" placeholder="1d6"/>
    </div>

    <div class="form-group damage-total-section">
        <div class="ability-selection" style="display: flex; gap: 15px; margin-bottom: 5px;">
            <label style="display: flex; align-items: center; gap: 5px;">
                <input type="checkbox" name="system.damage.useStrength" {{checked item.system.damage.useStrength}} data-mutually-exclusive="damage-ability"/>
                {{localize "CARDIGAN.Ability.Strength.abbr"}}
            </label>
            <label style="display: flex; align-items: center; gap: 5px;">
                <input type="checkbox" name="system.damage.useDexterity" {{checked item.system.damage.useDexterity}} data-mutually-exclusive="damage-ability"/>
                {{localize "CARDIGAN.Ability.Dexterity.abbr"}}
            </label>
        </div>
        <div class="form-group">
            <label for="system.damage.total">{{localize "CARDIGAN.DamageTotal"}}</label>
            <input type="text" name="system.damage.total" value="{{item.system.damage.total}}" readonly/>
        </div>
    </div>
    
    <div class="form-group weapon-properties">
        <div class="properties-header">
            <label>{{localize "CARDIGAN.WeaponProperties"}}</label>
            <button type="button" class="add-property-btn" data-action="addWeaponProperty" title="{{localize 'CARDIGAN.AddProperty'}}">+</button>
        </div>
        
        <div class="properties-list" data-properties-container>
            {{#if item.system.properties.length}}
                {{#each item.system.properties as |property index|}}
                    <div class="property-row" data-property-index="{{index}}">
                        <select name="system.properties.{{index}}" data-property-select>
                            <option value="">{{localize "CARDIGAN.SelectProperty"}}</option>
                            <option value="afiado" {{selected property "afiado"}}>{{localize "CARDIGAN.WeaponProperty.Afiado"}}</option>
                            <option value="ambidestria" {{selected property "ambidestria"}}>{{localize "CARDIGAN.WeaponProperty.Ambidestria"}}</option>
                            <option value="bomba" {{selected property "bomba"}}>{{localize "CARDIGAN.WeaponProperty.Bomba"}}</option>
                            <option value="colateral" {{selected property "colateral"}}>{{localize "CARDIGAN.WeaponProperty.Colateral"}}</option>
                            <option value="contundente" {{selected property "contundente"}}>{{localize "CARDIGAN.WeaponProperty.Contundente"}}</option>
                            <option value="discreto" {{selected property "discreto"}}>{{localize "CARDIGAN.WeaponProperty.Discreto"}}</option>
                            <option value="disparoividido" {{selected property "disparoividido"}}>{{localize "CARDIGAN.WeaponProperty.DispardividIdo"}}</option>
                            <option value="dosedupla" {{selected property "dosedupla"}}>{{localize "CARDIGAN.WeaponProperty.DoseDupla"}}</option>
                            <option value="duela" {{selected property "duela"}}>{{localize "CARDIGAN.WeaponProperty.Duela"}}</option>
                            <option value="eletrecutar" {{selected property "eletrecutar"}}>{{localize "CARDIGAN.WeaponProperty.Eletrecutar"}}</option>
                            <option value="extensao" {{selected property "extensao"}}>{{localize "CARDIGAN.WeaponProperty.Extensao"}}</option>
                            <option value="ferir" {{selected property "ferir"}}>{{localize "CARDIGAN.WeaponProperty.Ferir"}}</option>
                            <option value="impacto" {{selected property "impacto"}}>{{localize "CARDIGAN.WeaponProperty.Impacto"}}</option>
                            <option value="incendiar" {{selected property "incendiar"}}>{{localize "CARDIGAN.WeaponProperty.Incendiar"}}</option>
                            <option value="pente" {{selected property "pente"}}>{{localize "CARDIGAN.WeaponProperty.Pente"}}</option>
                            <option value="perfurar" {{selected property "perfurar"}}>{{localize "CARDIGAN.WeaponProperty.Perfurar"}}</option>
                            <option value="queimaroupa" {{selected property "queimaroupa"}}>{{localize "CARDIGAN.WeaponProperty.QueimaRoupa"}}</option>
                            <option value="recarga" {{selected property "recarga"}}>{{localize "CARDIGAN.WeaponProperty.Recarga"}}</option>
                            <option value="saquerapido" {{selected property "saquerapido"}}>{{localize "CARDIGAN.WeaponProperty.SaqueRapido"}}</option>
                            <option value="traspassar" {{selected property "traspassar"}}>{{localize "CARDIGAN.WeaponProperty.Traspassar"}}</option>
                            <option value="unica" {{selected property "unica"}}>{{localize "CARDIGAN.WeaponProperty.Unica"}}</option>
                            <option value="vorpal" {{selected property "vorpal"}}>{{localize "CARDIGAN.WeaponProperty.Vorpal"}}</option>
                        </select>
                        <button type="button" class="remove-property-btn" data-action="removeWeaponProperty" data-index="{{index}}" title="{{localize 'CARDIGAN.RemoveProperty'}}">−</button>
                    </div>
                {{/each}}
            {{else}}
                <div class="property-row" data-property-index="0">
                    <select name="system.properties.0" data-property-select>
                        <option value="">{{localize "CARDIGAN.SelectProperty"}}</option>
                        <option value="afiado">{{localize "CARDIGAN.WeaponProperty.Afiado"}}</option>
                        <option value="ambidestria">{{localize "CARDIGAN.WeaponProperty.Ambidestria"}}</option>
                        <option value="bomba">{{localize "CARDIGAN.WeaponProperty.Bomba"}}</option>
                        <option value="colateral">{{localize "CARDIGAN.WeaponProperty.Colateral"}}</option>
                        <option value="contundente">{{localize "CARDIGAN.WeaponProperty.Contundente"}}</option>
                        <option value="discreto">{{localize "CARDIGAN.WeaponProperty.Discreto"}}</option>
                        <option value="disparoividido">{{localize "CARDIGAN.WeaponProperty.DispardividIdo"}}</option>
                        <option value="dosedupla">{{localize "CARDIGAN.WeaponProperty.DoseDupla"}}</option>
                        <option value="duela">{{localize "CARDIGAN.WeaponProperty.Duela"}}</option>
                        <option value="eletrecutar">{{localize "CARDIGAN.WeaponProperty.Eletrecutar"}}</option>
                        <option value="extensao">{{localize "CARDIGAN.WeaponProperty.Extensao"}}</option>
                        <option value="ferir">{{localize "CARDIGAN.WeaponProperty.Ferir"}}</option>
                        <option value="impacto">{{localize "CARDIGAN.WeaponProperty.Impacto"}}</option>
                        <option value="incendiar">{{localize "CARDIGAN.WeaponProperty.Incendiar"}}</option>
                        <option value="pente">{{localize "CARDIGAN.WeaponProperty.Pente"}}</option>
                        <option value="perfurar">{{localize "CARDIGAN.WeaponProperty.Perfurar"}}</option>
                        <option value="queimaroupa">{{localize "CARDIGAN.WeaponProperty.QueimaRoupa"}}</option>
                        <option value="recarga">{{localize "CARDIGAN.WeaponProperty.Recarga"}}</option>
                        <option value="saquerapido">{{localize "CARDIGAN.WeaponProperty.SaqueRapido"}}</option>
                        <option value="traspassar">{{localize "CARDIGAN.WeaponProperty.Traspassar"}}</option>
                        <option value="unica">{{localize "CARDIGAN.WeaponProperty.Unica"}}</option>
                        <option value="vorpal">{{localize "CARDIGAN.WeaponProperty.Vorpal"}}</option>
                    </select>
                    <button type="button" class="remove-property-btn" data-action="removeWeaponProperty" data-index="0" title="{{localize 'CARDIGAN.RemoveProperty'}}">−</button>
                </div>
            {{/if}}
        </div>
    </div>

    <div class="form-group">
        <label for="system.weight">{{localize "CARDIGAN.Weight"}} (kg)</label>
        <input type="number" name="system.weight" value="{{item.system.weight}}" min="0" step="0.1"/>
    </div>
    
    <div class="form-group">
        <label for="system.price">{{localize "CARDIGAN.Price"}} (PO)</label>
        <input type="number" name="system.price" value="{{item.system.price}}" min="0"/>
    </div>
    
    <div class="form-group">
        <label for="system.durability.current">{{localize "CARDIGAN.Durability"}}</label>
        <div class="durability-container" style="display: flex; align-items: center; gap: 5px;">
            <input type="number" name="system.durability.current" value="{{item.system.durability.current}}" min="0" max="3" style="width: 60px;"/>
            <span>/</span>
            <span>{{item.system.durability.max}}</span>
        </div>
    </div>
</div>
