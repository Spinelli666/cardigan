{{! Item Comum Attributes Tab }}
<section
  class='tab attributes {{tab.cssClass}}'
  data-group='primary'
  data-tab='attributes'
>
  <div class="item-comum-header">
    <h3><i class="fas fa-box"></i> {{localize "CARDIGAN.ItemComum.Title"}}</h3>
    <p class="item-subtitle">{{localize "CARDIGAN.ItemComum.Subtitle"}}</p>
  </div>

  <div class="backpack-form-section">
    <div class="form-group">
      <label>{{localize "CARDIGAN.ItemComum.Quantity"}}</label>
      <div class="form-fields">
        <input type="number" name="system.quantity" value="{{system.quantity}}" data-dtype="Number" min="1"/>
      </div>
    </div>

    <div class="form-group">
      <label>{{localize "CARDIGAN.ItemComum.Weight"}}</label>
      <div class="form-fields">
        <input type="number" name="system.weight" value="{{system.weight}}" data-dtype="Number" step="0.1" min="0"/>
        <span class="unit">kg</span>
      </div>
    </div>
  </div>

  <div class="backpack-form-section">
    <div class="form-group">
      <label>{{localize "CARDIGAN.ItemComum.Category"}}</label>
      <div class="form-fields">
        <select name="system.category" data-dtype="String">
          <option value="equipment" {{#if (eq system.category "equipment")}}selected{{/if}}>
            {{localize "CARDIGAN.ItemComum.Categories.Equipment"}}
          </option>
          <option value="tool" {{#if (eq system.category "tool")}}selected{{/if}}>
            {{localize "CARDIGAN.ItemComum.Categories.Tool"}}
          </option>
          <option value="misc" {{#if (eq system.category "misc")}}selected{{/if}}>
            {{localize "CARDIGAN.ItemComum.Categories.Misc"}}
          </option>
          <option value="valuable" {{#if (eq system.category "valuable")}}selected{{/if}}>
            {{localize "CARDIGAN.ItemComum.Categories.Valuable"}}
          </option>
        </select>
      </div>
    </div>

    <div class="form-group">
      <label>{{localize "CARDIGAN.ItemComum.Price"}}</label>
      <div class="form-fields">
        <input type="number" name="system.price" value="{{system.price}}" data-dtype="Number" min="0"/>
        <span class="unit">{{localize "CARDIGAN.Currency.Gold"}}</span>
      </div>
    </div>
  </div>

  <div class="backpack-form-section">
    <div class="form-group full-width">
      <label>{{localize "CARDIGAN.ItemComum.Usage"}}</label>
      <div class="form-fields">
        <textarea name="system.usage" rows="3" placeholder="{{localize 'CARDIGAN.ItemComum.UsagePlaceholder'}}">{{system.usage}}</textarea>
      </div>
    </div>
  </div>
</section>