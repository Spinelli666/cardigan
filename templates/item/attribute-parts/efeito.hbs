{{!-- 
Template simplificado para itens do tipo efeito
Aba Details com campo de tipo (dropdown)
--}}
<section class='tab {{tab.cssClass}}' data-group='primary' data-tab='attributes'>
  <div class="form-group">
    <label>{{localize "CARDIGAN.Item.Efeito.FIELDS.efeitoType.label"}}</label>
    <select name="system.efeitoType">
      <option value="positivo" {{selected item.system.efeitoType "positivo"}}>{{localize "CARDIGAN.Item.Efeito.Types.Positivo"}}</option>
      <option value="negativo" {{selected item.system.efeitoType "negativo"}}>{{localize "CARDIGAN.Item.Efeito.Types.Negativo"}}</option>
    </select>
  </div>
</section>
