{{!-- Recipe Item Template --}}
<section class="tab {{tab.cssClass}}" data-group="primary" data-tab="attributes">
  
  <div class="recipe-details-form">
    
    {{!-- Basic Information --}}
    <fieldset class="recipe-section">
      <legend>{{localize "CARDIGAN.Item.ItemRecipe.basic.title"}}</legend>
      
      <div class="form-group">
        <label for="system.difficulty">{{localize "CARDIGAN.Item.ItemRecipe.difficulty.label"}}</label>
        <select name="system.difficulty">
          <option value="easy" {{#if (eq system.difficulty "easy")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.difficulty.easy"}}</option>
          <option value="medium" {{#if (eq system.difficulty "medium")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.difficulty.medium"}}</option>
          <option value="hard" {{#if (eq system.difficulty "hard")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.difficulty.hard"}}</option>
          <option value="master" {{#if (eq system.difficulty "master")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.difficulty.master"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label for="system.consumableType">{{localize "CARDIGAN.Item.ItemRecipe.consumableType.label"}}</label>
        <select name="system.consumableType">
          <option value="food" {{#if (eq system.consumableType "food")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.consumableType.food"}}</option>
          <option value="drink" {{#if (eq system.consumableType "drink")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.consumableType.drink"}}</option>
          <option value="potion" {{#if (eq system.consumableType "potion")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.consumableType.potion"}}</option>
          <option value="other" {{#if (eq system.consumableType "other")}}selected{{/if}}>{{localize "CARDIGAN.Item.ItemRecipe.consumableType.other"}}</option>
        </select>
      </div>
    </fieldset>

    {{!-- Crafting Process --}}
    <fieldset class="recipe-section">
      <legend>{{localize "CARDIGAN.Item.ItemRecipe.process.title"}}</legend>
      
      <div class="form-group">
        <label for="system.cookingTime">{{localize "CARDIGAN.Item.ItemRecipe.cookingTime.label"}}</label>
        <input
          type="number"
          name="system.cookingTime"
          value="{{system.cookingTime}}"
          min="1"
          placeholder="{{localize 'CARDIGAN.Item.ItemRecipe.cookingTime.hint'}}"
          data-dtype="Number"
        />
      </div>

      <div class="form-group">
        <label for="system.servings">{{localize "CARDIGAN.Item.ItemRecipe.servings.label"}}</label>
        <input
          type="number"
          name="system.servings"
          value="{{system.servings}}"
          min="1"
          placeholder="{{localize 'CARDIGAN.Item.ItemRecipe.servings.hint'}}"
          data-dtype="Number"
        />
      </div>
    </fieldset>

    {{!-- Item Properties --}}
    <fieldset class="recipe-section">
      <legend>{{localize "CARDIGAN.Item.ItemRecipe.properties.title"}}</legend>
      
      <div class="form-group">
        <label for="system.quantity">{{localize "CARDIGAN.Quantity"}}</label>
        <input
          type="number"
          name="system.quantity"
          value="{{system.quantity}}"
          min="1"
          data-dtype="Number"
        />
      </div>

      <div class="form-group">
        <label for="system.weight">{{localize "CARDIGAN.Weight"}}</label>
        <select name="system.weight">
          <option value="muito-leve" {{#if (eq system.weight "muito-leve")}}selected{{/if}}>{{localize "CARDIGAN.WeightType.muito-leve"}}</option>
          <option value="leve" {{#if (eq system.weight "leve")}}selected{{/if}}>{{localize "CARDIGAN.WeightType.leve"}}</option>
          <option value="medio" {{#if (eq system.weight "medio")}}selected{{/if}}>{{localize "CARDIGAN.WeightType.medio"}}</option>
          <option value="pesado" {{#if (eq system.weight "pesado")}}selected{{/if}}>{{localize "CARDIGAN.WeightType.pesado"}}</option>
          <option value="muito-pesado" {{#if (eq system.weight "muito-pesado")}}selected{{/if}}>{{localize "CARDIGAN.WeightType.muito-pesado"}}</option>
        </select>
      </div>

      <div class="form-group">
        <label for="system.price">{{localize "CARDIGAN.Price"}}</label>
        <input
          type="number"
          name="system.price"
          value="{{system.price}}"
          min="0"
          step="0.01"
          data-dtype="Number"
        />
      </div>
    </fieldset>

    {{!-- Effects and Notes --}}
    <fieldset class="recipe-section">
      <legend>{{localize "CARDIGAN.Item.ItemRecipe.effects.title"}}</legend>
      
      <div class="form-group">
        <label for="system.effects">{{localize "CARDIGAN.Item.ItemRecipe.effects.label"}}</label>
        <textarea
          name="system.effects"
          placeholder="{{localize 'CARDIGAN.Item.ItemRecipe.effects.hint'}}"
          rows="3"
        >{{system.effects}}</textarea>
      </div>
    </fieldset>

  </div>

</section>