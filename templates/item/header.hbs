<header class='sheet-header'>
  <div class='profile-img-wrapper' data-action='onEditImage' data-edit='img' title='{{item.name}}'>
    <img
      class='profile-img'
      src='{{item.img}}'
      alt='{{item.name}}'
    />
  </div>
  <div class='header-fields'>
    <div class='document-name'>
      <input name='name' type='text' value='{{item.name}}' placeholder='Name' />
    </div>
    {{! You may prefer to have a separate header file instead of this if statement}}
    {{#if (eq item.type 'backpack')}}
      <div class='grid grid-2col'>
        <div class='resource'>
          <label class='resource-label'>{{localize 'CARDIGAN.Item.Gear.FIELDS.quantity.label'}}</label>
          <input
            type='text'
            name='system.quantity'
            value='{{system.quantity}}'
            data-dtype='Number'
          />
        </div>
        <div class='resource'>
          <label class='resource-label'>{{localize 'CARDIGAN.Item.Gear.FIELDS.weight.label'}}</label>
          <input
            type='text'
            name='system.weight'
            value='{{system.weight}}'
            data-dtype='Number'
          />
        </div>
      </div>
    {{/if}}
  </div>
  <img src="systems/cardigan/assets/images/decorative/border.webp" class="header-border" alt="" />
</header>