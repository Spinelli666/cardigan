<div class="enhancement-config-dialog">
  <form>
    <div class="form-group description-group">
      <label for="enhancement-description">{{localize "CARDIGAN.Common.Description"}}</label>
      <prose-mirror
        name="description"
        data-document-u-u-i-d="{{document.uuid}}"
        value="{{enhancement.description}}"
        collaborate="true"
        toggled="true"
      >{{{enrichedDescription}}}</prose-mirror>
    </div>

    <div class="form-group energy-group">
      <label class="checkbox">
        <input type="checkbox" name="hasEnergy" {{#if enhancement.hasEnergy}}checked{{/if}} />
        <span>{{localize "CARDIGAN.Item.Skill.EnhancementConfig.ModifyEnergyCost"}}</span>
      </label>
      
      <div class="energy-cost-input" style="display: {{#if enhancement.hasEnergy}}block{{else}}none{{/if}};">
        <label for="energyCost">{{localize "CARDIGAN.Item.Skill.EnhancementConfig.NewEnergyCost"}}</label>
        <input 
          type="number" 
          name="energyCost" 
          id="energyCost" 
          value="{{enhancement.energyCost}}" 
          min="0" 
          placeholder="Ex: 5"
        />
        <p class="hint">{{localize "CARDIGAN.Item.Skill.EnhancementConfig.EnergyCostHint"}}</p>
      </div>
    </div>

    <div class="form-group effects-group">
      <label class="checkbox">
        <input type="checkbox" name="hasEffects" {{#if enhancement.hasEffects}}checked{{/if}} />
        <span>{{localize "CARDIGAN.Item.Skill.EnhancementConfig.ApplyEffects"}}</span>
      </label>
    </div>
  </form>
</div>