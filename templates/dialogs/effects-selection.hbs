<div class="effects-selection-dialog">
  <div class="search-bar">
    <i class="fas fa-search"></i>
    <input 
      type="text" 
      class="effect-search-input" 
      placeholder="Pesquisar efeitos..."
      autocomplete="off"
    />
    <button type="button" class="clear-search-button" title="Limpar pesquisa">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="effects-grid">
    {{#each effects as |effect|}}
      <div class="effect-item" data-effect-uuid="{{effect.uuid}}" data-rounds="0">
        <div class="rounds-counter">
          <img src="systems/cardigan/assets/images/decorative/icons/icon-clock.svg" alt="Rodadas" class="icon-clock" width="25" height="25">
          <button type="button" class="rounds-button" data-effect-uuid="{{effect.uuid}}">0</button>
        </div>
        <div class="effect-content">
          <div class="effect-icon-wrapper">
            <img src="{{effect.img}}" alt="{{effect.name}}" class="effect-icon" />
          </div>
          <div class="effect-info">
            <span class="effect-name">{{effect.name}}</span>
            {{#if effect.system.efeitoType}}
              <span class="effect-type effect-type-{{effect.system.efeitoType}}">
                {{#if (eq effect.system.efeitoType "positivo")}}Positivo{{else}}Negativo{{/if}}
              </span>
            {{/if}}
          </div>
        </div>
      </div>
    {{/each}}
  </div>

  {{#unless effects}}
    <div class="no-effects-message">
      <p>Nenhum efeito encontrado no compêndio.</p>
    </div>
  {{/unless}}

  <div class="dialog-buttons">
    <button type="button" class="confirm-button" data-action="addEffects">
      Adicionar
    </button>
  </div>
</div>
