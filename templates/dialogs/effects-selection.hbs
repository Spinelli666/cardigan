<div class="effects-selection-dialog">
  <img src="systems/cardigan/assets/images/decorative/border.webp" class="title-border" alt="">
  
  <div class="search-bar">
    <img src="systems/cardigan/assets/images/decorative/icons/icon-search.svg" alt="" class="search-icon">
    <input 
      type="text" 
      class="effect-search-input" 
      placeholder="Pesquisar efeitos..."
      autocomplete="off"
    />
    <button type="button" class="clear-search-button" title="Limpar pesquisa">
      <i class="fas fa-times"></i>
    </button>
  </div>

  <div class="effects-grid-wrapper">
    <div class="effects-grid">
      {{#each effects as |effect|}}
        <div class="effect-item" data-effect-uuid="{{effect.uuid}}" data-rounds="0">
          <div class="rounds-counter">
            <img src="systems/cardigan/assets/images/decorative/icons/icon-clock.svg" alt="Rodadas" class="icon-clock" width="20" height="20" data-tooltip="Rodadas" data-tooltip-class="cardigan-tooltip">
            <div class="rounds-button-wrapper">
              <button type="button" class="rounds-button" data-effect-uuid="{{effect.uuid}}">0</button>
            </div>
          </div>
          <div class="effect-content">
            <div class="effect-icon-wrapper">
              <img src="{{effect.img}}" alt="{{effect.name}}" class="effect-icon" />
            </div>
            <div class="effect-info">
              <span class="effect-name">{{effect.name}}</span>
              {{#if effect.system.effectType}}
                <span class="effect-type effect-type-{{effect.system.effectType}}">
                  {{#if (eq effect.system.effectType "positive")}}Positivo{{else}}Negativo{{/if}}
                </span>
              {{/if}}
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>

  {{#unless effects}}
    <div class="no-effects-message">
      <p>Nenhum efeito encontrado no compêndio.</p>
    </div>
  {{/unless}}

  <div class="dialog-buttons">
    <button type="button" class="confirm-button" data-action="addEffects">
      Adicionar
    </button>
  </div>
</div>
