<form class="character-creation-wizard">
  <div class="wizard-header">
    <h2>Criação de Personagem - Etapa {{currentStep}}/{{totalSteps}}</h2>
    <p class="step-title">{{stepTitle}}</p>
  </div>

  <div class="wizard-content">
    {{#if (eq currentStep 1)}}
      {{! Etapa 1: Seleção de Raça }}
      <div class="race-selection">
        <p class="instruction">Selecione a raça do seu personagem:</p>
        <div class="races-grid">
          {{#each races}}
            <div class="race-card {{#if selected}}selected{{/if}}" data-race-uuid="{{uuid}}">
              <img src="{{img}}" alt="{{name}}" />
              <h3>{{name}}</h3>
            </div>
          {{/each}}
        </div>
        <div class="race-description-display">
          <div class="description-placeholder">
            <i class="fas fa-info-circle"></i>
            <p>Clique em uma raça para ver sua descrição</p>
          </div>
        </div>
      </div>
    {{/if}}

    {{#if (eq currentStep 2)}}
      {{! Etapa 2: Seleção de Skills }}
      <div class="skill-selection">
        <p class="instruction">Selecione 2 habilidades iniciais. Você tem {{remainingPoints}} pontos restantes.</p>
        
        <div class="paths-grid">
          {{#each paths}}
            <div class="path-icon {{#if active}}active{{/if}}" data-action="selectPath" data-path-id="{{id}}">
              <img src="{{img}}" alt="{{name}}" />
              <span class="path-name">{{name}}</span>
              <span class="skill-count">{{skillCount}} skills</span>
            </div>
          {{/each}}
        </div>

        {{#if currentPathSkills}}
          <div class="skills-list">
            <h3>Habilidades - {{currentPathName}}</h3>
            {{#each currentPathSkills}}
              <div class="skill-item {{#if selected}}selected{{/if}}">
                <div class="skill-header" data-action="toggleSkillDetails" data-skill-id="{{id}}">
                  <img src="{{img}}" alt="{{name}}" class="skill-icon" />
                  <div class="skill-title">
                    <span class="skill-name">{{name}}</span>
                    {{#if skillActionTypes}}
                      <span class="skill-meta">
                        {{#each skillActionTypes}}{{this}}{{#unless @last}} • {{/unless}}{{/each}}
                        {{#if ../hasEnergyCost}} • Energia: {{../energyCost}}{{/if}}
                      </span>
                    {{/if}}
                  </div>
                  <button type="button" class="select-skill-btn {{#if selected}}selected{{/if}}" data-action="selectSkill" data-skill-uuid="{{uuid}}">
                    {{#if selected}}
                      <i class="fas fa-check-circle"></i>
                    {{else}}
                      <i class="far fa-circle"></i>
                    {{/if}}
                  </button>
                  <i class="fas fa-chevron-{{#if expanded}}up{{else}}down{{/if}} expand-icon"></i>
                </div>
                
                {{#if expanded}}
                  <div class="skill-details-wrapper">
                    {{#if spellCategories}}
                      <div class="spell-categories">
                        {{#each spellCategories}}
                          <img src="{{categoryImage}}" alt="{{categoryName}}" title="{{categoryName}}" />
                        {{/each}}
                      </div>
                    {{/if}}

                    <div class="skill-description">{{{description}}}</div>

                    {{#if enhancements}}
                      <div class="enhancements-section">
                        <h4>Aprimoramentos (1 ponto cada)</h4>
                        {{#each enhancements}}
                          <div class="enhancement-option {{#if isSelected}}selected{{/if}}" 
                               data-action="selectEnhancement" 
                               data-skill-uuid="{{../uuid}}" 
                               data-enhancement-index="{{@index}}">
                            <div class="enhancement-header">
                              <input type="checkbox" {{#if isSelected}}checked{{/if}} readonly>
                              <strong>{{name}}</strong>
                            </div>
                            {{#if description}}
                              <div class="enhancement-desc">{{{description}}}</div>
                            {{/if}}
                          </div>
                        {{/each}}
                      </div>
                    {{/if}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{else}}
          <div class="no-path-selected">
            <i class="fas fa-hand-pointer"></i>
            <p>Selecione um caminho acima para ver as habilidades disponíveis</p>
          </div>
        {{/if}}
      </div>
    {{/if}}

    {{#if (eq currentStep 3)}}
      {{! Etapa 3: Distribuição de Pontos nas Abilities }}
      <div class="ability-distribution">
        <div class="points-info">
          <div class="points-pool base-points">
            <i class="fas fa-star"></i>
            <span class="pool-label">Pontos Base:</span>
            <span class="points-count">{{basePointsUsed}}/{{baseAbilityPoints}}</span>
            <span class="points-hint">(máx. 3 por atributo)</span>
          </div>
          <div class="points-pool bonus-points">
            <i class="fas fa-plus-circle"></i>
            <span class="pool-label">Pontos Bônus:</span>
            <span class="points-count">{{bonusPointsUsed}}/{{bonusAbilityPoints}}</span>
            <span class="points-hint">(sem limite)</span>
          </div>
          <button type="button" 
                  class="randomize-button" 
                  data-action="randomizeAbilities"
                  title="Distribuir pontos aleatoriamente">
            <i class="fas fa-dice"></i> Aleatório
          </button>
        </div>

        <div class="abilities-grid">
          {{#each abilities}}
            <div class="ability-row">
              <div class="ability-label">
                <strong>{{label}}</strong>
                {{#if raceBonus}}
                  <span class="race-bonus" title="Bônus da Raça">+{{raceBonus}}</span>
                {{/if}}
              </div>
              <div class="ability-controls">
                <button type="button" 
                        class="ability-btn decrease" 
                        data-action="decreaseAbility" 
                        data-ability-key="{{key}}"
                        {{#unless canDecrease}}disabled{{/unless}}>
                  <i class="fas fa-minus"></i>
                </button>
                <div class="ability-value">
                  <span class="points-allocated">{{points}}</span>
                  {{#if raceBonus}}
                    <span class="points-separator">+</span>
                    <span class="points-race">{{raceBonus}}</span>
                    <span class="points-separator">=</span>
                    <span class="points-total">{{total}}</span>
                  {{else}}
                    <span class="points-total-single">= {{total}}</span>
                  {{/if}}
                </div>
                <button type="button" 
                        class="ability-btn increase" 
                        data-action="increaseAbility" 
                        data-ability-key="{{key}}"
                        {{#unless canIncrease}}disabled{{/unless}}>
                  <i class="fas fa-plus"></i>
                </button>
              </div>
            </div>
          {{/each}}
        </div>

        <div class="distribution-summary">
          <p><i class="fas fa-info-circle"></i> Distribua os 12 pontos base (máximo 3 por atributo) e depois os 3 pontos bônus (sem limite).</p>
        </div>
      </div>
    {{/if}}
    
    {{#if (eq currentStep 4)}}
      {{! Etapa 4: Seleção de Equipamentos }}
      <div class="equipment-selection">
        {{#unless budgetRolled}}
          <div class="budget-roller">
            <p class="instruction">Role os dados para determinar seu orçamento inicial de equipamentos:</p>
            <button type="button" class="roll-budget-button" data-action="rollBudget">
              <i class="fas fa-dice-d20"></i> Rolar Orçamento (4d100+100)
            </button>
            <p class="roll-info"><i class="fas fa-info-circle"></i> O sistema rolará duas vezes e escolherá o maior resultado!</p>
          </div>
        {{else}}
          <div class="budget-display">
            <div class="budget-card">
              <h3><i class="fas fa-coins"></i> Orçamento</h3>
              <div class="budget-values">
                <div class="budget-total">
                  <span class="label">Total:</span>
                  <span class="value">{{equipmentBudget}} <i class="fas fa-coins gold"></i></span>
                </div>
                <div class="budget-spent">
                  <span class="label">Gasto:</span>
                  <span class="value">{{totalSpent}} <i class="fas fa-coins spent"></i></span>
                </div>
                <div class="budget-remaining {{#if (lt remainingBudget 0)}}negative{{/if}}">
                  <span class="label">Restante:</span>
                  <span class="value">{{remainingBudget}} <i class="fas fa-coins remaining"></i></span>
                </div>
              </div>
            </div>
          </div>
          
          <div class="equipment-categories">
            <p class="instruction">Selecione os equipamentos que deseja comprar:</p>
            {{#each equipmentCategories}}
              <div class="equipment-category">
                <div class="category-header" data-action="toggleCategory" data-category-id="{{id}}">
                  <i class="fas fa-chevron-{{#if expanded}}down{{else}}right{{/if}}"></i>
                  <strong>{{name}}</strong>
                  <span class="item-count">({{items.length}} itens)</span>
                </div>
                {{#if expanded}}
                  <div class="category-items">
                    {{#each items}}
                      <div class="equipment-item {{#if selected}}selected{{/if}}" data-action="selectEquipment" data-item-uuid="{{uuid}}">
                        <img src="{{img}}" alt="{{name}}" class="item-icon" />
                        <div class="item-info">
                          <span class="item-name">{{name}}</span>
                          <span class="item-price">{{price}} <i class="fas fa-coins"></i></span>
                        </div>
                        {{#if selected}}
                          <i class="fas fa-check-circle selected-icon"></i>
                        {{/if}}
                      </div>
                    {{/each}}
                  </div>
                {{/if}}
              </div>
            {{/each}}
          </div>
        {{/unless}}
      </div>
    {{/if}}
  </div>

  <div class="wizard-footer">
    {{#if (eq currentStep 2)}}
      <div class="points-counter">
        <i class="fas fa-star"></i>
        Pontos: <span class="points-used">{{totalPointsUsed}}</span> / <span class="points-total">{{maxSkillPoints}}</span>
        {{#if selectedEnhancementsCount}}
          <span class="enhancements-info">({{selectedSkillsCount}} skills + {{selectedEnhancementsCount}} aprimoramentos)</span>
        {{/if}}
      </div>
    {{/if}}
    <button type="button" class="wizard-button previous" data-action="previousStep" {{#if isFirstStep}}disabled{{/if}}>
      <i class="fas fa-arrow-left"></i> Anterior
    </button>
    <button type="button" class="wizard-button cancel" data-action="cancel">
      <i class="fas fa-times"></i> Cancelar
    </button>
    <button type="button" class="wizard-button next" data-action="nextStep" {{#if isLastStep}}style="display:none;"{{/if}}>
      Próximo <i class="fas fa-arrow-right"></i>
    </button>
    <button type="button" class="wizard-button finish" data-action="finish" {{#unless isLastStep}}style="display:none;"{{/unless}}>
      <i class="fas fa-check"></i> Concluir
    </button>
  </div>
</form>
