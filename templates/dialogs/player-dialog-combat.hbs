<div class="attack-result-dialog">
  <div class="attack-result-container {{#if success}}success{{else}}failure{{/if}}">
    <div class="result-body">
      <div class="player-info">
        <div class="info-row">
          <strong>🎯 Atacante:</strong> 
          <span class="attacker-name">{{attackerName}}</span>
        </div>
        <div class="info-row">
          <strong>🛡️ Defensor:</strong> 
          <span class="defender-name">{{defenderName}}</span>
        </div>
      </div>
      
      <div class="combat-values">
        <div class="value-row">
          ⚔️ Ataque
          <span class="attack-value">{{attackTotal}}</span>
        </div>
        <div class="vs-separator">VS</div>
        <div class="value-row">
          🛡️ Evasão
          <span class="evasion-value">{{evasionTotal}}</span>
        </div>
      </div>
      
      <div class="damage-management">
        <h3>Gerenciamento de Dano</h3>
        
        <div class="damage-fields">
          <div class="field-group">
            <label>💥 Dano {{#if hasCritical}}(Crítico){{else}}Bruto{{/if}}:</label>
            <span class="damage-display">{{attackDamage}}</span>
          </div>
          
          <div class="field-group">
            <label>🚫 Ignore Armor:</label>
            <div class="ignore-armor-controls">
              <input type="number" class="ignore-armor-input" value="0" min="0" data-armor="{{armor}}" />
              <button type="button" class="roll-ignore-armor-btn" title="Rolar dado para Ignore Armor">
                <i class="fas fa-dice"></i>
              </button>
            </div>
          </div>
          
          <div class="field-group">
            <label>
              <input type="checkbox" class="ignore-all-armor-checkbox" />
              🛡️ Ignore All Armor
            </label>
          </div>
          
          <div class="field-group half-damage-group">
            <button type="button" class="half-damage-btn">
              <i class="fas fa-divide"></i> Dividir Dano por 2
            </button>
          </div>
          
          <div class="field-group final-damage-group">
            <label>💔 Dano Recebido:</label>
            <input type="number" class="damage-taken-input" value="{{damageTaken}}" min="0" />
          </div>
        </div>
      </div>
      
      <div class="armor-durability-row" style="margin-top: 16px; padding-top: 16px; border-top: 1px solid rgba(0, 0, 0, 0.1);">
        <h3 style="margin: 0 0 8px 0; font-size: 14px;">🛡️ Durabilidade de Armaduras</h3>
        <button type="button" class="select-armor-durability-btn" data-defender-id="{{defenderId}}" style="width: 100%; padding: 8px; margin-bottom: 8px; background: #4a90e2; color: white; border: none; border-radius: 4px; cursor: pointer; font-size: 13px;">
          <i class="fas fa-shield-halved"></i> Selecionar Armaduras para Danificar
        </button>
        <div class="selected-armors-display" style="font-size: 12px; color: #666; min-height: 20px;">
          <em>Nenhuma armadura selecionada</em>
        </div>
      </div>
    </div>
  </div>
</div>
