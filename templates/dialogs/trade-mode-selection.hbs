<div class="trade-mode-selection">
  <h2>
    <i class="fas fa-handshake"></i>Escolha o Modo de Negociação
  </h2>
  
  <div class="mode-options">
    <div class="mode-option" data-mode="normal">
      <div class="mode-icon">🤝</div>
      <div class="mode-details">
        <h3>Negociação Normal</h3>
        <p>Ambos os jogadores adicionam items livremente</p>
      </div>
    </div>
    
    <div class="mode-option" data-mode="merchant">
      <div class="mode-icon">🏪</div>
      <div class="mode-details">
        <h3>Modo Comerciante</h3>
        <p>Você vende items (inventário pré-preenchido)</p>
      </div>
    </div>
  </div>
</div>
